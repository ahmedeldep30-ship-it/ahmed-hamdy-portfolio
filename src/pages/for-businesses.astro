---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site, withBase } from '@config/site';

const problems = [
  ['Support demand keeps rising', 'Customers ask the same questions, escalations repeat or service quality varies even when the team is working hard.'],
  ['Sales interest does not become a decision', 'The offer, trust, information timing or handoff may be creating hesitation before price becomes the real objection.'],
  ['Work depends on one person', 'Ownership is informal, exceptions live in memory and the business slows down whenever the founder or one experienced employee is unavailable.'],
  ['The website or product feels harder than it should', 'The visible interface may be reflecting unclear business rules, unnecessary decisions or a journey designed around internal departments.'],
];
const outputs = [
  ['Problem definition', 'The symptom, likely root cause, affected journey and evidence still needed.'],
  ['Priority register', 'Issues ranked by recurrence, customer impact, commercial value, effort, risk and confidence.'],
  ['Future-state workflow', 'A clearer journey with ownership, handoffs, exception rules and decision points.'],
  ['Implementation brief', 'Requirements, responsibilities, success criteria and the specialists needed to deliver the change.'],
  ['Measurement plan', 'A practical baseline, KPI, review period and evidence needed to judge the result.'],
  ['30/60/90-day sequence', 'The smallest useful changes first, with larger builds delayed until the evidence justifies them.'],
];
---

<BaseLayout title={`For Businesses — ${site.name}`} description="A structured business diagnostic for customer, support, process, service-quality and operating problems." path="/for-businesses">
  <section class="page-hero business-hero">
    <div class="wrap page-hero__grid">
      <div class="reveal is-visible"><span class="eyebrow">For businesses</span><h1>The first answer is not always the real fix.</h1></div>
      <div class="stack reveal is-visible" style="--stack-gap:1.5rem"><p class="page-hero__copy">I help founders and teams diagnose where customer experience, team performance and operating workflows are losing value—then turn the evidence into a practical action plan.</p><p class="page-hero__note">A diagnostic does not begin with a preferred solution. It begins with what customers experience, how the work actually moves and what the business is trying to protect or improve.</p><a class="btn btn--primary" href={withBase('/contact?intent=diagnostic')}>Request a business diagnostic</a></div>
    </div>
  </section>

  <section class="section zone-paper">
    <div class="wrap">
      <header class="section-head reveal"><div><span class="eyebrow">Problems I help diagnose</span><h2>Small signals that often point to a wider system problem.</h2></div><p>You do not need to know the name of the problem before the conversation. “Something feels harder than it should” is often enough to start gathering the right evidence.</p></header>
      <div class="problem-field">
        {problems.map(([title,copy],index)=><article class={`problem problem--${index+1} reveal`}><span>{String(index+1).padStart(2,'0')}</span><h3>{title}</h3><p>{copy}</p></article>)}
        <div class="problem-core">Find the shared constraint</div>
      </div>
    </div>
  </section>

  <section class="section diagnostic-section">
    <div class="wrap">
      <header class="section-head reveal"><div><span class="eyebrow">What the diagnostic reviews</span><h2>Four evidence streams. One business question.</h2></div><p>The exact depth depends on the problem and available access. Confidential data is not requested before the scope and handling are agreed.</p></header>
      <div class="evidence-streams reveal">
        <article><span>Customer</span><h3>What people ask, expect, hesitate over and repeat.</h3><p>Questions, complaints, objections, abandoned journeys, reviews and support demand.</p></article>
        <article><span>Team</span><h3>What employees need to deliver a consistent outcome.</h3><p>Guidance, tools, knowledge, workload, quality patterns and escalation behaviour.</p></article>
        <article><span>Workflow</span><h3>How the work moves when nobody is drawing the ideal process.</h3><p>Ownership, handoffs, waiting, repeated input, exceptions and founder dependency.</p></article>
        <article><span>Performance</span><h3>Which indicators help answer the business question.</h3><p>Relevant volume, timing, quality, conversion, retention or capacity signals—not a dashboard for its own sake.</p></article>
      </div>
    </div>
  </section>

  <section class="section zone-paper output-section">
    <div class="wrap">
      <header class="section-head reveal"><div><span class="eyebrow">What you receive</span><h2>A decision package, not a long report that creates more work.</h2></div><p>The deliverables are sized to the problem. A focused workflow issue should not require a strategy deck; a cross-functional problem needs more than a list of quick wins.</p></header>
      <div class="output-grid">{outputs.map(([title,copy],index)=><article class="reveal"><span>{String(index+1).padStart(2,'0')}</span><h3>{title}</h3><p>{copy}</p></article>)}</div>
    </div>
  </section>

  <section class="section coordination-section">
    <div class="wrap coordination-shell reveal">
      <div><span class="eyebrow">From diagnosis to implementation</span><h2>I define and coordinate the business change. Specialists own their craft.</h2></div>
      <div class="coordination-flow"><span>Business evidence</span><i>→</i><span>Clear requirement</span><i>→</i><span>Design / engineering / content / operations</span><i>→</i><span>Measured result</span></div>
      <p>I can stay involved to clarify requirements, align priorities and review whether the implementation solves the original problem. Visual design, software engineering and advanced analytics remain with the relevant specialists.</p>
    </div>
  </section>

  <section class="section zone-paper business-cta"><div class="wrap business-cta__inner reveal"><div><span class="eyebrow">Start with the problem</span><h2>Send the context you already have. I will tell you what evidence is missing.</h2></div><a class="btn btn--primary" href={withBase('/contact?intent=diagnostic')}>Build a structured brief</a></div></section>
</BaseLayout>

<style>
  .business-hero { background: radial-gradient(circle at 85% 26%,rgba(255,122,97,.15),transparent 24rem),radial-gradient(circle at 8% 78%,rgba(72,224,187,.12),transparent 22rem),var(--night); }
  .problem-field { position:relative;display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding:0 3rem; }
  .problem{min-height:220px;padding:2rem;box-shadow:var(--shadow-soft)}.problem span{color:rgba(7,26,36,.47);font:850 .6rem var(--font-head)}.problem h3{margin:1.5rem 0 .7rem;font-size:1.45rem}.problem p{color:var(--ink-soft);font-size:.84rem}.problem--1{border-radius:68% 32% 55% 45%/42% 63% 37% 58%;background:var(--signal-soft)}.problem--2{border-radius:38% 62% 69% 31%/64% 38% 62% 36%;background:var(--coral-soft)}.problem--3{border-radius:42% 58% 35% 65%/57% 40% 60% 43%;background:var(--sky-soft)}.problem--4{border-radius:61% 39% 46% 54%/39% 63% 37% 61%;background:#ece4ff}.problem-core{position:absolute;z-index:3;left:50%;top:50%;width:150px;height:150px;display:grid;place-items:center;padding:1.2rem;color:var(--white);border-radius:50%;background:var(--night-soft);box-shadow:var(--shadow-deep),0 0 0 16px rgba(7,26,36,.04);text-align:center;transform:translate(-50%,-50%);font:850 .75rem/1.3 var(--font-head);text-transform:uppercase}
  .diagnostic-section{background:radial-gradient(circle at 12% 30%,rgba(121,183,255,.13),transparent 24rem),var(--night-soft)}.evidence-streams{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.evidence-streams article{min-height:260px;padding:1.6rem;border:1px solid var(--hairline);border-radius:var(--shape-md);background:rgba(255,255,255,.045)}.evidence-streams span{color:var(--signal);font:850 .62rem var(--font-head);letter-spacing:.12em;text-transform:uppercase}.evidence-streams h3{margin:1.5rem 0 .75rem;font-size:1.22rem}.evidence-streams p{color:var(--slate);font-size:.8rem}
  .output-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.output-grid article{min-height:210px;padding:1.6rem;border:1px solid var(--paper-line);border-radius:var(--shape-md);background:rgba(255,255,255,.62);box-shadow:var(--shadow-soft)}.output-grid span{color:var(--signal-deep);font:850 .6rem var(--font-head)}.output-grid h3{margin:1.4rem 0 .65rem}.output-grid p{color:var(--ink-soft);font-size:.8rem}
  .coordination-section{background:var(--night)}.coordination-shell{padding:clamp(2rem,5vw,4.5rem);border:1px solid var(--hairline);border-radius:74px 24px 82px 30px;background:radial-gradient(circle at 90% 15%,rgba(72,224,187,.12),transparent 20rem),rgba(255,255,255,.04)}.coordination-shell h2{max-width:850px;margin-top:1rem;font-size:var(--fs-h2)}.coordination-flow{display:flex;align-items:center;gap:.85rem;margin:2.4rem 0;padding:1.2rem 1.5rem;color:var(--ink);border-radius:var(--shape-md);background:var(--acid);font:850 .7rem var(--font-head)}.coordination-flow i{font-style:normal}.coordination-shell>p{max-width:760px;color:var(--slate)}
  .business-cta__inner{display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:center;padding:clamp(2rem,5vw,4rem);border-radius:var(--shape-lg);background:var(--coral-soft);box-shadow:var(--shadow-soft)}.business-cta h2{max-width:820px;margin-top:.8rem;font-size:var(--fs-h2)}
  @media(max-width:900px){.evidence-streams{grid-template-columns:1fr 1fr}.output-grid{grid-template-columns:1fr 1fr}.coordination-flow{flex-wrap:wrap}.business-cta__inner{grid-template-columns:1fr}}
  @media(max-width:620px){.problem-field{grid-template-columns:1fr;padding:0 0 145px}.problem:nth-child(even){width:94%;margin-left:6%}.problem-core{top:auto;bottom:0;transform:translate(-50%,0)}.evidence-streams,.output-grid{grid-template-columns:1fr}}
</style>
