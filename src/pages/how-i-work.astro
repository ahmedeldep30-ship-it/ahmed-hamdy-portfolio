---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site, withBase } from '@config/site';

const stages = [
  ['Understand', 'Clarify the business context, customer, current process, goal, constraints and evidence already available.'],
  ['Diagnose', 'Map the journey and handoffs, group recurring signals and separate the visible symptom from the likely cause.'],
  ['Prioritize', 'Rank what matters by recurrence, customer impact, business value, confidence, effort, risk and feasibility.'],
  ['Define', 'Describe the future-state outcome, workflow, ownership, requirement, exception and success criteria.'],
  ['Coordinate', 'Translate the decision into a clear brief and align the relevant business, content, design, product or technical specialists.'],
  ['Measure', 'Set a baseline, review period and evidence needed to judge whether the change improved the real outcome.'],
];
---

<BaseLayout title={`How I Work — ${site.name}`} description="Ahmed Hamdy's method for turning customer and operating evidence into prioritized workflows, requirements and measurable decisions." path="/how-i-work">
  <section class="page-hero method-hero"><div class="wrap page-hero__grid"><div class="reveal is-visible"><span class="eyebrow">How I work</span><h1>Start with the system. End with a decision somebody can own.</h1></div><div class="stack reveal is-visible" style="--stack-gap:1.4rem"><p class="page-hero__copy">I do not begin by choosing a tool, feature or department to blame. I begin with the customer outcome, the work as it happens and the evidence behind the pattern.</p><p class="page-hero__note">The method is deliberately practical: understand → diagnose → prioritize → define → coordinate → measure.</p></div></div></section>

  <section class="section zone-paper method-section"><div class="wrap"><header class="section-head reveal"><div><span class="eyebrow">The operating method</span><h2>Six steps, with a clear output at each one.</h2></div><p>The sequence can be compressed for a small workflow or expanded for a cross-functional problem. The logic stays the same.</p></header><ol class="method-path">{stages.map(([title,copy],index)=><li class="reveal"><span>{String(index+1).padStart(2,'0')}</span><div><h3>{title}</h3><p>{copy}</p></div></li>)}</ol></div></section>

  <section class="section worked-example"><div class="wrap"><header class="section-head reveal"><div><span class="eyebrow">Worked example</span><h2>“Where is my order?” is a question. The contact pattern is evidence.</h2></div><p>This is an illustrative operating pattern, not a client result. It shows how I reason without inventing a metric.</p></header><div class="example-flow reveal"><div class="example-flow__signal"><span>Visible signal</span><strong>Customers repeatedly ask for delivery status.</strong></div><i>→</i><div><span>Evidence to compare</span><strong>Promise, checkout copy, status visibility, handoffs and exception ownership.</strong></div><i>→</i><div><span>Likely constraint</span><strong>Expectations and operational status are not carried through the same journey.</strong></div><i>→</i><div class="example-flow__decision"><span>Defined change</span><strong>Clarify the promise, expose useful status and assign ownership before adding support capacity.</strong></div></div></div></section>

  <section class="section zone-paper sab-section"><div class="wrap"><header class="section-head reveal"><div><span class="eyebrow">Intervention discipline</span><h2>Simplify first. Automate second. Build only when the problem requires it.</h2></div><p>Every new feature, automation or AI layer creates an operating obligation. The decision should be worth the cost of keeping it accurate, safe and useful.</p></header><div class="sab-flow"><article class="reveal"><span>01</span><h3>Simplify</h3><p>Remove duplicated steps, clarify the sentence, improve ownership or change the sequence.</p><small>Best when the work is unclear rather than technically constrained.</small></article><i>→</i><article class="reveal reveal-delay-1"><span>02</span><h3>Automate</h3><p>Automate a stable, repetitive step only after its rules and exceptions are understood.</p><small>Best when the process is already reliable enough to repeat.</small></article><i>→</i><article class="reveal reveal-delay-2"><span>03</span><h3>Build</h3><p>Define product requirements when a new capability is necessary and the evidence supports the cost.</p><small>Best when simplification and existing tools cannot deliver the outcome.</small></article></div><div class="sab-test reveal"><strong>Before automation or AI:</strong><span>What can go wrong?</span><span>Who reviews the output?</span><span>When does a human take over?</span><span>What evidence shows it is better?</span></div></div></section>

  <section class="section deliverables"><div class="wrap"><header class="section-head reveal"><div><span class="eyebrow">Typical outputs</span><h2>The work leaves behind more than advice.</h2></div><p>Outputs depend on the decision, not on a fixed consulting package.</p></header><div class="deliverable-grid"><article><h3>Business diagnosis</h3><p>Problem statement, evidence map, root-cause hypotheses and priority register.</p></article><article><h3>Customer journey</h3><p>Current and future-state journey, friction log, trust requirements and communication changes.</p></article><article><h3>Operations</h3><p>Workflow, ownership model, SOP, exception rules and capacity risks.</p></article><article><h3>Requirements</h3><p>User need, business rule, acceptance criteria, dependencies and rollout sequence.</p></article><article><h3>Team & quality</h3><p>Quality review structure, calibration method, coaching priorities and knowledge gaps.</p></article><article><h3>Measurement</h3><p>Business question, baseline, useful KPI, review period and decision threshold.</p></article></div></div></section>

  <section class="section zone-paper method-cta"><div class="wrap method-cta__inner reveal"><div><span class="eyebrow">Use the method</span><h2>Bring the symptom. We can work backwards to the real question.</h2></div><a class="btn btn--primary" href={withBase('/contact')}>Start a conversation</a></div></section>
</BaseLayout>

<style>
  .method-hero{background:radial-gradient(circle at 84% 25%,rgba(201,243,111,.11),transparent 24rem),radial-gradient(circle at 8% 78%,rgba(187,165,255,.12),transparent 23rem),var(--night)}
  .method-path{position:relative;display:grid;grid-template-columns:1fr 1fr;gap:1rem 4rem}.method-path::before{content:'';position:absolute;left:50%;top:0;bottom:0;width:2px;background:linear-gradient(var(--signal),var(--coral),var(--sky),var(--signal))}.method-path li{position:relative;display:grid;grid-template-columns:48px 1fr;gap:1rem;min-height:170px;padding:1.6rem;border:1px solid var(--paper-line);border-radius:var(--shape-md);background:rgba(255,255,255,.62);box-shadow:var(--shadow-soft)}.method-path li:nth-child(even){margin-top:3rem}.method-path li>span{width:44px;height:44px;display:grid;place-items:center;color:var(--ink);border-radius:52% 48% 40% 60%/45% 58% 42% 55%;background:var(--acid);font:850 .62rem var(--font-head)}.method-path h3{font-size:1.35rem}.method-path p{margin-top:.65rem;color:var(--ink-soft);font-size:.82rem}
  .worked-example{background:radial-gradient(circle at 10% 25%,rgba(72,224,187,.12),transparent 22rem),var(--night-soft)}.example-flow{display:grid;grid-template-columns:repeat(7,auto);align-items:center;gap:.8rem}.example-flow>div{min-height:200px;padding:1.5rem;border:1px solid var(--hairline);border-radius:var(--shape-md);background:rgba(255,255,255,.045)}.example-flow span{color:var(--signal);font:850 .58rem var(--font-head);letter-spacing:.12em;text-transform:uppercase}.example-flow strong{display:block;margin-top:1.3rem;font:760 .9rem/1.5 var(--font-head)}.example-flow>i{color:var(--signal);font-style:normal}.example-flow__signal{background:rgba(255,122,97,.1)!important}.example-flow__decision{color:var(--ink);border-color:transparent!important;background:var(--acid)!important}.example-flow__decision span{color:var(--signal-deep)}
  .sab-flow{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;gap:1rem;align-items:center}.sab-flow article{min-height:280px;padding:2rem;border:1px solid var(--paper-line);border-radius:var(--shape-md);background:rgba(255,255,255,.66);box-shadow:var(--shadow-soft)}.sab-flow article>span{color:var(--signal-deep);font:850 .62rem var(--font-head)}.sab-flow h3{margin:2rem 0 .75rem;font-size:1.7rem}.sab-flow p{color:var(--ink-soft);font-size:.86rem}.sab-flow small{display:block;margin-top:1.2rem;padding-top:1.2rem;color:var(--slate-soft);border-top:1px solid var(--paper-line);font-size:.72rem}.sab-flow>i{color:var(--signal-deep);font-style:normal}.sab-test{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2rem;padding:1.4rem;border-radius:var(--shape-md);color:var(--white);background:var(--night-soft)}.sab-test strong{margin-right:auto;font:800 .8rem var(--font-head)}.sab-test span{padding:.35rem .6rem;border:1px solid var(--hairline);border-radius:var(--shape-pill);color:var(--slate);font-size:.7rem}
  .deliverables{background:var(--night)}.deliverable-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.deliverable-grid article{min-height:180px;padding:1.5rem;border:1px solid var(--hairline);border-radius:var(--shape-md);background:rgba(255,255,255,.045)}.deliverable-grid h3{font-size:1.2rem}.deliverable-grid p{margin-top:.8rem;color:var(--slate);font-size:.8rem}.method-cta__inner{display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:center;padding:clamp(2rem,5vw,4rem);border-radius:var(--shape-lg);background:var(--signal-soft);box-shadow:var(--shadow-soft)}.method-cta h2{max-width:780px;margin-top:.8rem;font-size:var(--fs-h2)}
  @media(max-width:900px){.example-flow{grid-template-columns:1fr}.example-flow>i{justify-self:center;transform:rotate(90deg)}.sab-flow{grid-template-columns:1fr}.sab-flow>i{justify-self:center;transform:rotate(90deg)}.deliverable-grid{grid-template-columns:1fr 1fr}.method-cta__inner{grid-template-columns:1fr}}
  @media(max-width:620px){.method-path{grid-template-columns:1fr;padding-left:2rem}.method-path::before{left:.7rem}.method-path li:nth-child(even){margin-top:0}.deliverable-grid{grid-template-columns:1fr}}
</style>
