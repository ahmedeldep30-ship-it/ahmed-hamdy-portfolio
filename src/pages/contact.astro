---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { contact, site, withBase } from '@config/site';

/**
 * The no-JavaScript fallback for the talk dialog.
 *
 * This replaces a 373-line page carrying the old design language and a
 * consultation builder — a form that assembled a structured message and opened
 * WhatsApp or email pre-filled. That was a reasonable idea honestly built; it
 * was not fake. But Ahmed's read stands: it looked like a different website,
 * and asking someone to answer five questions before they can say hello is a
 * toll booth in front of a conversation he wants to have.
 *
 * Every "Talk" link on the site points here and is upgraded by script into the
 * dialog. This page is what remains when that script does not run: the same
 * three channels, the same sentence about what the conversation costs, and
 * nothing to fill in.
 */
const CHANNELS = [
  { href: contact.emailHref, k: 'Email', v: contact.email, note: 'Best for anything with detail in it.', external: false },
  { href: contact.whatsapp, k: 'WhatsApp', v: '+20 104 002 0093', note: 'Fastest. Text is fine — I do not need a call to start.', external: true },
  { href: contact.linkedin, k: 'LinkedIn', v: 'ahmed-hamdy-growth-operations', note: 'If you would rather see the profile first.', external: true },
];
---

<BaseLayout
  title={`Talk to Ahmed Hamdy — ${site.role}`}
  description="Three direct channels. No form, nothing to fill in, and the first conversation is free."
  path="/contact"
>
  <section class="ct zone-night">
    <div class="wrap ct__grid">
      <div>
        <p class="eyebrow">Talk to me</p>
        <h1 class="ct__h">Tell me what is not working.</h1>
        <p class="ct__lede">No form, and nothing to fill in. These three reach me directly, and I answer them myself.</p>
        <p class="ct__free">
          <strong>The first conversation is free, and it is not a favour.</strong> An hour inside a real
          problem teaches me more than a month of reading about one, so I get as much out of it as you do.
          Bring the thing that is actually annoying you &mdash; not the tidy version.
        </p>
        <p class="ct__fine">
          Messages are read and answered personally. I do not promise a response time, because I will not
          promise one I cannot keep. If the problem is not a fit for what I do, I will say so &mdash; that
          is useful to both of us.
        </p>
        <a class="ct__back" href={withBase('/')}>&larr; Back to the work</a>
      </div>

      <ul class="ct__list">
        {CHANNELS.map((c) => (
          <li>
            <a class="ct__chan" href={c.href} rel={c.external ? 'noopener' : undefined}>
              <span class="ct__k">{c.k}</span>
              <span class="ct__v">{c.v}</span>
              <span class="ct__n">{c.note}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .ct { padding: clamp(7rem, 12vw, 10rem) 0 clamp(4rem, 8vw, 6rem); color: var(--chalk); background: radial-gradient(circle at 82% 18%, rgba(121,183,255,.16), transparent 24rem), radial-gradient(circle at 6% 84%, rgba(72,224,187,.12), transparent 25rem), linear-gradient(135deg,#04151e 0%,#082632 63%,#0a303a 100%); }
  .ct__grid { display: grid; grid-template-columns: minmax(0,1.05fr) minmax(300px,.95fr); gap: clamp(2rem,5vw,4rem); align-items: start; }
  .ct__h { margin: .7rem 0 1rem; max-width: 14ch; color: var(--white); font-size: clamp(2.4rem,1.6rem + 3vw,4rem); letter-spacing: -.03em; }
  .ct__lede { max-width: 52ch; color: var(--slate); font-size: 1rem; line-height: 1.65; }
  .ct__free { max-width: 60ch; margin-top: 1.6rem; padding: 1rem 1.2rem; border-left: 2px solid var(--acid); border-radius: 0 16px 16px 0; background: rgba(201,243,111,.07); color: var(--slate); font-size: .86rem; line-height: 1.65; }
  .ct__free strong { color: var(--chalk); font-weight: 750; }
  .ct__fine { max-width: 62ch; margin-top: 1.4rem; color: var(--slate-soft); font-size: .78rem; line-height: 1.6; }
  .ct__back { display: inline-block; margin-top: 1.8rem; color: var(--signal); font: 800 .82rem var(--font-head); text-decoration: none; }
  .ct__back:hover { color: var(--acid); }

  .ct__list { display: grid; gap: .8rem; margin: 0; padding: 0; list-style: none; }
  .ct__chan { display: grid; gap: .15rem; padding: 1.2rem 1.4rem; border: 1px solid var(--hairline); border-radius: 34px 12px 38px 14px; background: rgba(255,255,255,.045); text-decoration: none; transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease); }
  .ct__chan:hover { border-color: var(--signal); background: rgba(72,224,187,.08); }
  .ct__chan:focus-visible { outline: 2px solid var(--acid); outline-offset: 3px; }
  .ct__k { color: var(--signal); font: 850 .58rem var(--font-head); letter-spacing: .14em; text-transform: uppercase; }
  .ct__v { color: var(--white); font: 750 1rem var(--font-head); overflow-wrap: anywhere; }
  .ct__n { color: var(--slate); font-size: .78rem; }

  @media (max-width: 860px) { .ct__grid { grid-template-columns: 1fr; } }
  @media (prefers-reduced-motion: reduce) { .ct__chan { transition: none; } }
</style>
