---
import { contact, withBase, site } from '@config/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer__grid">
    <div class="footer__identity">
      <span class="footer__mark">AH</span>
      <div>
        <strong>Ahmed Hamdy</strong>
        <p>{site.role} · Alexandria, Egypt</p>
      </div>
    </div>

    <nav aria-label="Portfolio">
      <span>Explore</span>
      <a href={withBase('/work')}>Selected work</a>
      <a href={withBase('/how-i-work')}>How I work</a>
      <a href={withBase('/about')}>About</a>
    </nav>
    <nav aria-label="Audience routes">
      <span>Choose a route</span>
      <a href={withBase('/for-employers')}>For employers</a>
      <a href={withBase('/for-businesses')}>For businesses</a>
      <a href={withBase('/contact')}>Contact</a>
    </nav>
    <nav aria-label="Direct contact">
      <span>Go direct</span>
      <a href={contact.linkedin} rel="noopener">LinkedIn ↗</a>
      <a href={contact.emailHref}>Email</a>
      <a href={contact.whatsapp} rel="noopener">WhatsApp</a>
    </nav>
  </div>
  <div class="wrap footer__bottom">
    <p>© {year} Ahmed Hamdy. Built to show the work, the reasoning and the boundary of each contribution.</p>
    <p>Messages are read and answered personally.</p>
  </div>
</footer>

<style>
  .footer { padding: 4.5rem 0 2rem; color: var(--chalk); border-top: 1px solid var(--hairline); background: #04131b; }
  .footer__grid { display: grid; grid-template-columns: minmax(260px,1.6fr) repeat(3,minmax(130px,.55fr)); gap: 2.5rem; }
  .footer__identity { display: flex; align-items: center; gap: 1rem; }
  .footer__mark { width: 52px; height: 52px; display: grid; place-items: center; border: 1px solid var(--hairline-strong); border-radius: 60% 40% 67% 33% / 48% 62% 38% 52%; color: var(--signal); font: 850 .8rem var(--font-head); }
  .footer__identity strong { font: 800 1rem var(--font-head); }
  .footer__identity p, .footer__bottom { color: var(--slate-soft); font-size: .75rem; }
  .footer nav { display: flex; flex-direction: column; gap: .48rem; }
  .footer nav span { margin-bottom: .35rem; color: var(--slate-soft); font: 800 .62rem var(--font-head); letter-spacing: .13em; text-transform: uppercase; }
  .footer nav a { color: var(--chalk); font: 650 .82rem var(--font-head); text-decoration: none; }
  .footer nav a:hover { color: var(--signal); }
  .footer__bottom { display: flex; justify-content: space-between; gap: 1.5rem; margin-top: 3rem; padding-top: 1.2rem; border-top: 1px solid var(--hairline); }
  @media (max-width: 850px) { .footer__grid { grid-template-columns: 1fr 1fr; } .footer__identity { grid-column: 1 / -1; } }
  @media (max-width: 520px) { .footer__grid { grid-template-columns: 1fr; } .footer__identity { grid-column: auto; } .footer__bottom { flex-direction: column; } }
</style>
