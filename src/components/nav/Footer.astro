---
import { contact, external, withBase, site } from '@config/site';

const year = new Date().getFullYear();
const channels = [
  { label: 'WhatsApp', href: contact.whatsapp, note: 'Fastest route' },
  { label: 'Email', href: contact.emailHref, note: contact.email },
  { label: 'Phone', href: contact.phoneHref, note: contact.phoneDisplay },
  { label: 'LinkedIn', href: contact.linkedin, note: 'Professional profile' },
  { label: 'Facebook', href: contact.facebook, note: 'Arabic-language content' },
];
---

<footer class="ft zone-deep">
  <div class="wrap">
    <div class="ft__top">
      <div class="stack" style="--stack-gap: var(--s3)">
        <span class="ft__name">Ahmed Hamdy</span>
        <p class="faint">{site.role} · {site.location.city}, {site.location.country}</p>
        <p class="faint">Available for roles and business-diagnostic engagements.</p>
      </div>

      <nav class="ft__chan" aria-label="Contact channels">
        {channels.map((c) => (
          <a href={c.href} rel={c.href.startsWith('http') ? 'noopener' : undefined}>
            <span class="ft__chan-l">{c.label}</span>
            <span class="faint">{c.note}</span>
          </a>
        ))}
      </nav>

      <nav class="ft__links" aria-label="Site">
        <a href={withBase('/work')}>Work</a>
        <a href={withBase('/work/formula4you')}>Formula4You</a>
        <a href={withBase('/contact')}>Contact</a>
        <a href={external.formula4you} rel="noopener">formula4you.com ↗</a>
      </nav>
    </div>

    <hr class="resolve-rule" />

    <div class="ft__bot">
      <p class="faint">© {year} Ahmed Hamdy. Built as a static site — no tracking, no third-party data collection.</p>
      <p class="faint">No response-time is promised. Messages are read personally.</p>
    </div>
  </div>
</footer>

<style>
  .ft { border-top: 1px solid var(--hairline); padding-block: var(--s8) var(--s6); }
  .ft__top { display: grid; gap: var(--s7); grid-template-columns: 1.2fr 1fr auto; margin-bottom: var(--s6); }
  .ft__name { font-family: var(--font-head); font-weight: 700; font-size: 1.125rem; }
  .ft__chan { display: grid; gap: var(--s3); }
  .ft__chan a { display: flex; flex-direction: column; text-decoration: none; color: var(--text); }
  .ft__chan a:hover .ft__chan-l { color: var(--teal-bright); }
  .ft__chan-l { font-family: var(--font-head); font-weight: 600; font-size: var(--fs-small); }
  .ft__links { display: flex; flex-direction: column; gap: var(--s3); }
  .ft__links a { font-family: var(--font-head); font-size: var(--fs-small); font-weight: 600; color: var(--text-muted); text-decoration: none; }
  .ft__links a:hover { color: var(--teal-bright); }
  .ft__bot { display: flex; justify-content: space-between; gap: var(--s4); flex-wrap: wrap; margin-top: var(--s5); }
  @media (max-width: 860px) { .ft__top { grid-template-columns: 1fr; gap: var(--s6); } }
</style>
