---
import { withBase } from '@config/site';

interface Props { path: string }
const { path } = Astro.props;
const isHome = path === '/';

/**
 * A mark, not a navigation bar.
 *
 * The old header was a full tab bar: brand block on the left, four section
 * links in the middle, two route links and a CTA on the right. On a portfolio
 * — and especially a SINGLE-PAGE one — that is a control panel bolted above a
 * story. There is nowhere to navigate to. You scroll.
 *
 * So: one centred mark. It sits quietly at the top, and on scroll it shrinks
 * into a compact pill that keeps the name and one way to reach him. The
 * section index lives in the hero instead, where it can actually show the
 * shape of the page rather than hide it behind four words.
 */
---

<header class:list={['mark', { 'mark--home': isHome }]} data-mark>
  <a class="mark__id" href={withBase('/')} aria-label="Ahmed Hamdy — home">
    <span class="mark__dot" aria-hidden="true"></span>
    <span class="mark__name">Ahmed Hamdy</span>
    <span class="mark__sep" aria-hidden="true"></span>
    <span class="mark__role">Business Operations &amp; Process</span>
  </a>
  <a class="mark__talk" href={withBase('/contact')}>Talk<span aria-hidden="true"> ↗</span></a>
</header>

<style>
  .mark {
    position: fixed; z-index: 60;
    top: 1.1rem; left: 50%;
    display: flex; align-items: center; gap: .35rem;
    padding: .4rem .45rem .4rem .95rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: rgba(6, 24, 34, .62);
    backdrop-filter: blur(18px) saturate(140%);
    box-shadow: 0 12px 34px rgba(2, 12, 18, .28);
    transform: translateX(-50%);
    transition: padding var(--dur-mid) var(--ease),
                background var(--dur-mid) var(--ease),
                border-color var(--dur-mid) var(--ease);
  }

  .mark__id {
    display: flex; align-items: center; gap: .55rem;
    color: var(--chalk); text-decoration: none;
    font: 750 .74rem var(--font-head); letter-spacing: -.01em;
    white-space: nowrap;
  }
  .mark__dot {
    width: 6px; height: 6px; border-radius: 50%; flex: none;
    background: var(--signal);
    box-shadow: 0 0 0 3px rgba(72, 224, 187, .18);
  }
  .mark__sep { width: 1px; height: 11px; background: var(--hairline-strong); }
  .mark__role {
    color: var(--slate);
    font-weight: 600; font-size: .68rem;
    transition: max-width var(--dur-mid) var(--ease), opacity var(--dur-mid) var(--ease);
    max-width: 20rem; overflow: hidden;
  }

  .mark__talk {
    padding: .4rem .8rem;
    border-radius: 999px;
    background: var(--signal);
    color: var(--ink); text-decoration: none;
    font: 800 .7rem var(--font-head);
    transition: background var(--dur-fast) var(--ease);
  }
  .mark__talk:hover { background: var(--acid); }
  .mark__id:focus-visible, .mark__talk:focus-visible {
    outline: 2px solid var(--acid); outline-offset: 3px; border-radius: 999px;
  }

  /* Scrolled: the role drops away and the mark tightens to just the name.
     Less furniture the further you are into the argument. */
  .mark[data-scrolled] { background: rgba(6, 24, 34, .86); border-color: var(--hairline-strong); }
  .mark[data-scrolled] .mark__role { max-width: 0; opacity: 0; }
  .mark[data-scrolled] .mark__sep { display: none; }

  @media (max-width: 560px) {
    .mark { top: .7rem; padding-left: .8rem; }
    .mark__role, .mark__sep { display: none; }
    .mark__name { font-size: .7rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mark, .mark__role { transition: none; }
  }
</style>

<script>
  const mark = document.querySelector<HTMLElement>('[data-mark]');
  if (mark) {
    let ticking = false;
    const sync = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        if (window.scrollY > 120) mark.setAttribute('data-scrolled', '');
        else mark.removeAttribute('data-scrolled');
      });
    };
    window.addEventListener('scroll', sync, { passive: true });
    sync();
  }
</script>
