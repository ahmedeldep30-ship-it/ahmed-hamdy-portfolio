---
import { withBase } from '@config/site';

interface Props { path: string }
const { path } = Astro.props;
const isHome = path === '/';
const links = [
  { label: 'Work', href: '/work' },
  { label: 'How I Work', href: '/how-i-work' },
  { label: 'Insights', href: '/insights' },
  { label: 'About', href: '/about' },
];
const active = (href: string) => path === href || (href !== '/' && path.startsWith(`${href}/`));
---

<header class:list={['hdr', { 'hdr--home': isHome }]}>
  <div class="wrap hdr__inner">
    <a class="hdr__brand" href={withBase('/')} aria-label="Ahmed Hamdy, home">
      <span class="hdr__mark">AH</span>
      <span>
        <strong>Ahmed Hamdy</strong>
        <small>Business Growth &amp; Operations</small>
      </span>
    </a>

    <nav class="hdr__nav" aria-label="Primary navigation">
      {links.map((link) => (
        <a href={withBase(link.href)} aria-current={active(link.href) ? 'page' : undefined}>{link.label}</a>
      ))}
    </nav>

    <div class="hdr__routes">
      <a href={withBase('/for-employers')}>For employers</a>
      <a href={withBase('/for-businesses')}>For businesses</a>
      <a class="hdr__contact" href={withBase('/contact')}>Talk to me <span aria-hidden="true">↗</span></a>
    </div>

    <button class="hdr__burger no-js-hide" type="button" aria-expanded="false" aria-controls="mobile-menu">
      <span class="visually-hidden">Open navigation</span>
      <span></span><span></span>
    </button>
  </div>

  <div class="hdr__mobile" id="mobile-menu" hidden>
    <nav class="wrap" aria-label="Mobile navigation">
      {links.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
      <a href={withBase('/for-employers')}>For employers</a>
      <a href={withBase('/for-businesses')}>For businesses</a>
      <a class="btn btn--primary" href={withBase('/contact')}>Start a conversation</a>
    </nav>
  </div>
</header>

<style>
  .hdr { position: sticky; z-index: 100; top: 0; color: var(--chalk); border-bottom: 1px solid var(--hairline); background: color-mix(in srgb, var(--night) 91%, transparent); backdrop-filter: blur(18px); }
  .hdr--home { position: absolute; width: 100%; background: linear-gradient(to bottom, rgba(2,16,23,.62), transparent); border-bottom-color: transparent; }
  .hdr__inner { min-height: 82px; display: flex; align-items: center; gap: 1.6rem; }
  .hdr__brand { display: flex; align-items: center; gap: .75rem; flex: none; color: inherit; text-decoration: none; }
  .hdr__mark { width: 42px; height: 42px; display: grid; place-items: center; border: 1px solid var(--hairline-strong); border-radius: 58% 42% 65% 35% / 55% 60% 40% 45%; background: rgba(255,255,255,.07); box-shadow: inset 0 0 22px rgba(72,224,187,.08); font: 800 .75rem var(--font-head); letter-spacing: -.04em; }
  .hdr__brand strong, .hdr__brand small { display: block; }
  .hdr__brand strong { font: 800 .82rem var(--font-head); }
  .hdr__brand small { margin-top: .17rem; color: rgba(255,255,255,.47); font: 700 .48rem var(--font-head); letter-spacing: .14em; text-transform: uppercase; }
  .hdr__nav { display: flex; gap: 1.55rem; margin-left: auto; }
  .hdr__nav a, .hdr__routes > a:not(.hdr__contact) { position: relative; color: rgba(255,255,255,.67); font: 750 .72rem var(--font-head); text-decoration: none; white-space: nowrap; }
  .hdr__nav a::after { content: ''; position: absolute; left: 0; right: 0; bottom: -.65rem; height: 2px; border-radius: 2px; background: var(--signal); transform: scaleX(0); transform-origin: left; transition: transform var(--dur-mid) var(--ease); }
  .hdr__nav a:hover, .hdr__nav a[aria-current='page'], .hdr__routes a:hover { color: var(--white); }
  .hdr__nav a:hover::after, .hdr__nav a[aria-current='page']::after { transform: scaleX(1); }
  .hdr__routes { display: flex; align-items: center; gap: 1rem; padding-left: 1.25rem; border-left: 1px solid var(--hairline); }
  .hdr__contact { position: relative; min-height: 42px; display: inline-flex; align-items: center; padding: 0 1rem; color: var(--ink); border-radius: var(--shape-pill); background: var(--signal); font: 800 .72rem var(--font-head); text-decoration: none; }
  .hdr__contact::after { content: ''; position: absolute; left: -.3rem; bottom: -.28rem; width: .7rem; height: .7rem; border-radius: 50%; background: var(--signal); }
  .hdr__burger { display: none; width: 44px; height: 42px; margin-left: auto; padding: 0; border: 1px solid var(--hairline-strong); border-radius: var(--shape-sm); background: rgba(255,255,255,.06); }
  .hdr__burger span:not(.visually-hidden) { display: block; width: 18px; height: 1px; margin: 5px auto; background: var(--white); }
  .hdr__mobile { padding: 1.2rem 0 1.5rem; border-top: 1px solid var(--hairline); background: var(--night); }
  .hdr__mobile nav { display: grid; gap: .3rem; }
  .hdr__mobile nav > a:not(.btn) { padding: .65rem 0; color: var(--chalk); font: 750 .92rem var(--font-head); text-decoration: none; border-bottom: 1px solid var(--hairline); }
  .hdr__mobile .btn { margin-top: 1rem; justify-self: start; }
  @media (max-width: 1110px) { .hdr__nav, .hdr__routes { display: none; } .hdr__burger { display: block; } }
  @media (max-width: 560px) { .hdr__brand small { display: none; } .hdr__inner { min-height: 70px; } }
</style>

<script>
  const trigger = document.querySelector<HTMLButtonElement>('.hdr__burger');
  const menu = document.getElementById('mobile-menu');
  trigger?.addEventListener('click', () => {
    const open = trigger.getAttribute('aria-expanded') === 'true';
    trigger.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
</script>
