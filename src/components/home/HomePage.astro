  .who__strengths { position: sticky; top: 6rem; padding: clamp(1.4rem, 2.5vw, 2rem); border: 1px solid var(--paper-line); border-radius: 40px 14px 44px 16px; background: var(--paper-bright); }
  .who__k { display: block; margin-bottom: 1rem; color: var(--signal-deep); font: 850 .6rem var(--font-head); letter-spacing: .14em; text-transform: uppercase; }
  .who__strengths ul { display: grid; gap: .85rem; margin: 0; padding: 0; list-style: none; }
