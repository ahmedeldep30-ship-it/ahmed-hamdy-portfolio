---
import { Image } from 'astro:assets';
import portrait from '@/assets/portrait/ahmed-hamdy-portrait-approved.webp';
import formulaHome from '@/assets/formula4you/formula4you-platform-home.webp';
import { external, withBase } from '@config/site';
import Disclosure from '@/components/Disclosure.astro';

/**
 * CONTENT NOTE — why this reads the way it does.
 *
 * The previous copy described a method in the abstract: "I map how work moves",
 * "I review clarity and trust". True of every consultant alive, and therefore
 * evidence of nothing. Ahmed's verdict was correct — it read as generated.
 *
 * The rule applied here: every claim is either something he did, something he
 * decided, or something he refused. No adjective stacking. No parallel
 * three-bullet symmetry. Where the evidence stops, the copy says so.
 */

const capabilities = [
  {
    index: '01',
    title: 'Customer Experience & Support Operations',
    teaser: 'The same question arriving hundreds of times is not hundreds of problems. It is one thing upstream that nobody fixed.',
    color: 'signal',
    body: [
      'I spent two years answering Arabic-speaking customers for a UK fintech — remote, high volume, every day. You get fast at the answer. Then you notice the answer is not the point.',
      'Somebody promised something in sales. A page never mentioned a delivery time. A process took three days and told nobody. The complaint lands on support. The cause almost never does.',
      'So I stopped trying to answer faster and started asking why the question existed at all.',
    ],
    leaves: [
      'A contact-driver map — what people actually ask, ranked by how often and how avoidable',
      'Answers written in the customer\'s words, placed at the moment of doubt',
      'An escalation path that names who decides, not just who replies',
      'The list of contacts that should stop existing, and what has to change upstream for that',
    ],
    proof: 'Alpha Capital Group — built the support system, then managed it',
  },
  {
    index: '02',
    title: 'Process & Workflow Improvement',
    teaser: 'A process is not scalable because it has many steps. It is scalable when the right work happens once and the customer never feels the internal complexity.',
    color: 'sky',
    body: [
      'The question I ask first is not "how do we automate this?" It is "what stops existing if we do nothing?"',
      'Most of what looks like a capacity problem is repeated work: the same data asked for twice, a status that lives in one person\'s head, an exception that has no path so it becomes a management interruption.',
      'Automating that makes the waste faster and harder to see. So simplification comes first, always.',
    ],
    leaves: [
      'How the work actually moves — not the diagram somebody drew once',
      'Where it waits, who owns it, and where it becomes invisible',
      'Exception rules, so unusual cases stop being escalations',
      'A written brief the person doing the building can act on',
    ],
    proof: 'Formula4You — listing lifecycle, admin review, governance',
  },
  {
    index: '03',
    title: 'Team Development & Service Quality',
    teaser: 'An agent looks slow. Then you check the cases: they are getting the hard ones. That is a routing problem wearing a performance problem\'s clothes.',
    color: 'violet',
    body: [
      'I did not start as a manager. I started as the person answering — which is why I do not read a quality dashboard the way a manager who never sat in the chair reads it.',
      'Coaching cannot repair a policy that is unfair. Training cannot fix an article nobody can find. Before I say a person is underperforming, I check what the system around them is doing to their work.',
      'When it genuinely is the person, that conversation is easier — because by then they trust that I looked everywhere else first.',
    ],
    leaves: [
      'A quality view that accounts for case mix, not just handling time',
      'Calibration — so two reviewers score the same case the same way',
      'The difference between a knowledge gap, a tools gap, and a judgment gap',
      'Standards for what "good" sounds like, written down instead of assumed',
    ],
    proof: 'Alpha Capital Group — response standards and case guidance',
  },
  {
    index: '04',
    title: 'Customer-Led Business Improvement',
    teaser: 'Customers describe your operating model back to you every day. Most companies file it as tickets.',
    color: 'coral',
    body: [
      'Every objection is a market research interview you already paid for. Every abandoned order is a page that failed to answer something. Every repeated complaint is a process telling you where it breaks.',
      'This is the part I think most businesses waste. The evidence is already in the building — in the inbox, the chat log, the refund reasons — and it gets treated as noise to be cleared rather than signal to be read.',
      'I read it, and turn it into decisions someone can actually take: change the sentence, change the policy, change the sequence, or — occasionally — build the thing.',
    ],
    leaves: [
      'The recurring themes, with what each one is actually costing',
      'Which are content problems, which are policy, which are product',
      'A ranked list — by recurrence, harm, effort and confidence',
      'A decision, an owner, and how we will know if it worked',
    ],
    proof: 'Alpha Capital Group and founder-led commercial work',
  },
];

/**
 * The boundary section. This exists because a portfolio that claims everything
 * proves nothing — and because a company that hires him expecting a designer or
 * a data engineer will be disappointed, which serves nobody.
 */
const lenses = [
  ['Customer Journey & Conversion Review', 'I can tell you where a journey loses people and why — information arriving too late, a decision that needs making twice, a trust signal that is missing. I write the requirement. I do not open Figma and design the screen.'],
  ['Business Performance Interpretation', 'I start from the business question, pick the indicator that actually answers it, and read what the pattern means. I am not a data engineer and I do not build the pipeline.'],
  ['Product Requirements & Prioritization', 'I define the problem, the need, the acceptance logic, and whether building is warranted at all. The architecture and the code belong to engineers.'],
  ['AI-Aware Workflow Decisions', 'I decide where to simplify, where to automate, and where an AI feature would add cost without touching the cause. Knowing when not to build it is the skill. I am not an ML engineer.'],
  ['Digital Commerce & Platform Operations', 'Founder-led: participant journeys, onboarding, trust, operating rules, and coordinating the people who implement. I am not the developer who shipped it.'],
];
---

<div class="home">
  <section class="hero" aria-labelledby="home-title">
    <div class="wrap hero__grid">
      <div class="hero__copy reveal is-visible">
        <p class="eyebrow">Ahmed Hamdy · Business Growth &amp; Operations Specialist</p>
        {/* Three beats, then the turn. The old headline — "Different teams see
            different problems, I connect the pattern" — was true of any
            consultant, which is why it read as generated. This one names three
            departments (the breadth) and lands on the insight that is actually
            his. */}
        <h1 id="home-title">It shows up in support. It slows down sales. <span>It started somewhere else.</span></h1>
        <p class="hero__lede">That gap is my job. I spent two years in the seat where a company's failures arrive as complaints — the clearest view in the building of what is actually broken. I trace a problem back past the department it lands in, and design the smallest change that stops it.</p>
        <p class="hero__depth">Customer Experience · Support Operations · Process Improvement · Team Development · Service Quality</p>
        <div class="cluster hero__actions">
          <a class="btn btn--primary" href="#diagnosis">See how I take it apart <span class="btn__arrow" aria-hidden="true">↓</span></a>
          <a class="btn" href="#evidence">Where I have done it <span class="btn__arrow" aria-hidden="true">→</span></a>
        </div>

        {/* The whole page, on the first screen.
            "The person should understand what they will see" — so show them.
            Six labels beats a scroll bar for telling someone how much is here
            and whether it is worth their time. */}
        <nav class="hero__index" aria-label="On this page">
          {[
            ['01', 'The diagnosis', '#diagnosis'],
            ['02', 'What I go deep on', '#capabilities'],
            ['03', 'Evidence', '#evidence'],
            ['04', 'Where I stop', '#boundary'],
            ['05', 'Why I see it this way', '#about'],
            ['06', 'Talk', '#talk'],
          ].map(([n, label, href]) => (
            <a href={href}><span>{n}</span>{label}</a>
          ))}
        </nav>
      </div>

      <div class="system-lens" aria-label="Customer, support, sales and operations signals converging around Ahmed's portrait">
        <span class="lens-orbit lens-orbit--one"></span>
        <span class="lens-orbit lens-orbit--two"></span>
        <span class="lens-orbit lens-orbit--three"></span>
        <div class="portrait-frame" data-parallax="-0.35">
          <Image src={portrait} alt="Ahmed Hamdy" widths={[360, 540, 720]} sizes="(max-width: 760px) 230px, 300px" loading="eager" />
          <span>Business signal → operating decision</span>
        </div>
        <span class="lens-core">Root cause</span>
        <span class="orbit-node orbit-node--support" data-parallax="0.65">Support signal</span>
        <span class="orbit-node orbit-node--sales" data-parallax="-0.45">Sales friction</span>
        <span class="orbit-node orbit-node--ops" data-parallax="0.5">Operating constraint</span>
        <span class="orbit-node orbit-node--customer" data-parallax="-0.6">Customer behaviour</span>
      </div>
    </div>
  </section>

  <div class="journey" id="diagnosis">
    <svg class="journey__spine" viewBox="0 0 1440 2680" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="journey-gradient" x1="0" y1="0" x2="0" y2="1">
          <stop stop-color="#48e0bb" />
          <stop offset=".34" stop-color="#ff7a61" />
          <stop offset=".68" stop-color="#79b7ff" />
          <stop offset="1" stop-color="#48e0bb" />
        </linearGradient>
      </defs>
      <path class="journey__glow" d="M735 0C720 185 1040 230 930 470C820 700 455 615 510 900C558 1140 1015 1040 960 1320C902 1610 445 1500 520 1810C582 2070 970 1980 814 2680" />
      <path class="journey__line" d="M735 0C720 185 1040 230 930 470C820 700 455 615 510 900C558 1140 1015 1040 960 1320C902 1610 445 1500 520 1810C582 2070 970 1980 814 2680" />
      <circle cx="930" cy="470" r="11" stroke="#ff7a61" />
      <circle cx="510" cy="900" r="11" stroke="#c9f36f" />
      <circle cx="960" cy="1320" r="11" stroke="#79b7ff" />
      <circle cx="520" cy="1810" r="11" stroke="#48e0bb" />
    </svg>

    <section class="signal-section zone-paper">
      <div class="wrap">
        <header class="section-head reveal">
          <div><span class="eyebrow">A worked diagnosis</span><h2>The question reaches support. The cause may sit somewhere else.</h2></div>
          <div><p>A customer asks where their order is. You can answer that. You can answer it two hundred times. What you cannot do is answer your way out of the reason they had to ask.</p><span class="scenario-label">Illustrative operating pattern</span></div>
        </header>

        {/* Four cards of identical length, each politely observing the same
            thing, is what a generated page looks like. The teams do not see
            the same amount — sales sees nothing at all — so the cards should
            not be the same size or the same temperature. */}
        <div class="signal-map">
          <article class="signal-island signal-island--support reveal">
            <span>Support sees</span><h3>The same question, again.</h3>
            <p>Two hundred conversations, each one handled well, each one ending with a customer who got their answer. By every measure the team is performing. The queue still grows.</p>
          </article>
          <article class="signal-island signal-island--sales reveal reveal-delay-1">
            <span>Sales sees</span><h3>Nothing.</h3>
            <p>The order closed. Nobody comes back to mention that the sentence which closed it — “quick delivery, don’t worry about it” — is now arriving in someone else’s inbox as a complaint.</p>
          </article>
          <article class="signal-island signal-island--ops reveal reveal-delay-2">
            <span>Operations sees</span><h3>An order that is moving fine.</h3>
            <p>Because it is. It is on schedule and the status is correct. It just lives somewhere the customer cannot look, and it changes hands twice on the way.</p>
          </article>
          <article class="signal-island signal-island--lead reveal reveal-delay-3">
            <span>Management sees</span><h3>A headcount request.</h3>
            <p>Support volume is up, so support needs people. It is the obvious read. It is also the one read that costs money and changes nothing.</p>
          </article>
          <div class="signal-map__core"><strong>Expectation + visibility + ownership</strong><small>The operating constraint</small></div>
        </div>
      </div>
    </section>

    <section class="decision-section zone-night" id="how-home">
      <div class="wrap decision-shell">
        <header class="section-head reveal">
          <div><span class="eyebrow">From signal to decision</span><h2>Trace the pattern before fixing the symptom.</h2></div>
          <p>My role sits between evidence and execution: make the problem clear, connect the people involved and define a move the business can defend.</p>
        </header>

        {/* These were Understand / Diagnose / Prioritize / Define / Coordinate /
            Measure — the same six words every consultant on earth prints. Same
            structure, but each one now says something only he would say. */}
        <ol class="decision-path reveal">
          <li><span>01</span><h3>Read the raw</h3><p>The actual conversations, not the summary. A summary is already somebody's interpretation of what matters.</p></li>
          <li><span>02</span><h3>Find the promise</h3><p>Someone upstream promised, implied, or failed to mention something. That is usually where it starts.</p></li>
          <li><span>03</span><h3>Ask what disappears</h3><p>Before asking what to build: what stops existing if we change one sentence, one field, one owner?</p></li>
          <li><span>04</span><h3>Write it down</h3><p>The outcome, the rule, the owner, the signal. If it is not written, it is a conversation, not a decision.</p></li>
          <li><span>05</span><h3>Hand it over</h3><p>I brief the specialist who builds it. I do not pretend to be that specialist.</p></li>
          <li><span>06</span><h3>Check honestly</h3><p>Against a baseline agreed beforehand. If it did not move, I say it did not move.</p></li>
        </ol>
        <div class="decision-note reveal"><strong>In this case the answer was three timed updates and one sentence moved earlier on the page. Not a chatbot, not more agents, not a tracking product. The cheapest thing that removed the reason to ask.</strong></div>
      </div>
    </section>

    <section class="impact-section zone-paper">
      <div class="wrap">
        <header class="section-head reveal">
          <div><span class="eyebrow">What that actually changed</span><h2>Three timed updates and one moved sentence. Here is who felt it — and who paid for it.</h2></div>
          <p>Most fixes move a cost rather than remove it. Support goes quiet because operations quietly starts doing the chasing. The only honest test is whether the total work went down — not whether it moved somewhere you stopped measuring.</p>
        </header>

        {/* Every department improving by exactly one tidy sentence is a
            consultant's slide, not an outcome. Real changes have a loser.
            Naming ours is the only reason to believe the rest. */}
        <div class="impact-system">
          <article class="impact-petal impact-petal--support reveal"><span>Customer support</span><h3>The question mostly stops.</h3><p>Not because agents got faster. Because the customer already had the answer before they thought to ask for it.</p></article>
          <article class="impact-petal impact-petal--sales reveal reveal-delay-1"><span>Sales</span><h3>The comfortable sentence goes away.</h3><p>“Quick delivery” becomes a specific number. That is a harder thing to say on a call — and it is the part of this that sales genuinely lost.</p></article>
          <article class="impact-petal impact-petal--ops reveal reveal-delay-2"><span>Operations</span><h3>Three moments that belong to someone.</h3><p>Ownership stops being ambient and becomes a named person at a named point. That is new work. It is also why the rest of the work disappears.</p></article>
          <article class="impact-petal impact-petal--lead reveal reveal-delay-3"><span>Leadership</span><h3>The headcount request never arrives.</h3><p>Not approved, not rejected — no longer a question. Which is a genuinely awkward win to present, because it looks like nothing happened.</p></article>
          <div class="impact-core"><span>The net</span><strong>Less work overall. One team lost something.</strong></div>
        </div>
      </div>
    </section>
  </div>

  <section class="capability-section zone-paper" id="capabilities">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">Where I add depth</span><h2>Four things I can go deep on. Open the one you care about.</h2></div>
        <p>Not a service list. Each one opens onto how I actually think about it, and what you are left holding afterwards.</p>
      </header>

      {/* Collapsed by default: title + a line that has to earn the click.
          Depth exists without the page demanding you read all of it. */}
      <div class="capability-list reveal">
        {capabilities.map((capability) => (
          <Disclosure index={capability.index} title={capability.title} teaser={capability.teaser} tone="paper">
            <div class={`cap-body cap-body--${capability.color}`}>
              {capability.body.map((para) => <p>{para}</p>)}
              <p class="cap-body__k">What you are left holding</p>
              <ul class="cap-body__list">{capability.leaves.map((item) => <li>{item}</li>)}</ul>
              <p class="cap-body__proof">{capability.proof}</p>
            </div>
          </Disclosure>
        ))}
      </div>
    </div>
  </section>

  <section class="proof-section zone-raised" id="evidence">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">Evidence behind the thinking</span><h2>Two different environments shaped the same operating judgment.</h2></div>
        <p>Alpha Capital comes first because it shows customer depth and career progression inside an international company. Formula4You follows as founder-led evidence of ownership and wider business decisions.</p>
      </header>

      <div class="proof-grid">
        {/* The link here pointed at /work/alpha-capital, which does not exist —
            a 404 in the proof section, of all places. On a single-page site the
            depth belongs in a disclosure, not another route. */}
        <article class="alpha-proof reveal">
          <span class="proof-label">Alpha Capital Group · UK fintech, remote · 2024 — present</span>
          <h3>I did not start as the manager. That is the whole point.</h3>
          <p>The five-star reviews on my name are not a manager's metric. They are two years of being the person a frustrated customer actually reached — in Arabic, at the moment they were losing patience. You cannot delegate that view of a company. You have to sit in it.</p>
          <div class="alpha-proof__flow">
            <span>Answered it</span><i></i><span>Noticed the pattern</span><i></i><span>Built the system</span>
          </div>

          <Disclosure
            index="→"
            title="What I actually built there"
            teaser="Not articles. A reason for the question to stop being asked."
            tone="paper"
          >
            <p><strong>The knowledge base.</strong> Not "content" — answers written in the words customers actually used, placed at the moment of doubt rather than filed where only staff could find them. An article titled in company language is an article nobody finds.</p>
            <p><strong>Escalation paths.</strong> Who decides, not just who replies. Most escalations are not hard cases; they are cases where nobody owns the exception, so the whole thing stops until a manager is interrupted.</p>
            <p><strong>Response standards.</strong> So the answer is the same whoever gives it. Inconsistency is not a people problem — it is a governance problem wearing a people problem's clothes.</p>
            <p><strong>The part that mattered most:</strong> working across sales, operations and product, because that is where the causes were. Support was where the failure arrived. It was almost never where it started.</p>
            <p class="alpha-note">
              <strong>Evidence status.</strong> The title Support Team Manager and the progression into it are my own statement — recorded as user-asserted until documentary proof is attached. Employee of the Month and the exact review count are held back until the certificate and review evidence exist; the site says "hundreds of five-star reviews" and no number until then.
            </p>
          </Disclosure>
        </article>

        <article class="formula-proof reveal reveal-delay-1">
          <div class="formula-proof__image"><Image src={formulaHome} alt="The live Formula4You specialist fragrance-commerce platform" widths={[520, 760, 1040]} sizes="(max-width: 900px) 100vw, 42vw" /></div>
          <div class="formula-proof__copy">
            <span class="proof-label">Verified live platform · founder-led work</span>
            <h3>The other half of the job: deciding what gets built at all.</h3>
            <p>Alpha Capital shows I can read a system from inside it. This shows the harder half — that when the decision is mine and there is nobody to escalate to, I still pick the boring correct thing over the impressive one.</p>
            <p>Live, with real participants: who may list, what happens when a listing is wrong, what a buyer is owed, who fixes it. Operating rules are not documentation. They are what the business does at 2am when nobody is watching.</p>
            <p class="formula-proof__role">Founder — Business Growth, Customer Experience &amp; Platform Operations</p>

            <div class="cluster">
              <a class="btn btn--primary" href={withBase('/work/formula4you')}>Read the case</a>
              <a class="btn" href={external.formula4you} rel="noopener">Visit live platform ↗</a>
            </div>
          </div>
        </article>
      </div>

      {/* Ahmed worked with a lot of small Egyptian companies and kept no
          records of any of it. The tempting move is a vague "10+ businesses"
          line nobody can check. The stronger move is to say out loud that he
          will not do that — because a reader who watches him refuse an
          unverifiable number has a reason to believe the verifiable ones. */}
      <div class="field-notes reveal">
        <span class="proof-label">Unverifiable by design</span>
        <h3>Before either of these, there were a lot of small Egyptian companies.</h3>
        <div class="field-notes__grid">
          <div class="field-notes__say">
            <p>I kept no records. No contracts I can show you, no dashboards, no before-and-after. So I am not going to name them, and I am not going to attach a number to any of it — a figure I cannot source is just a guess in a better suit.</p>
            <p>What survived is the pattern. Small companies break in remarkably consistent ways, and almost never the way the founder thinks they do:</p>
          </div>
          <ul class="field-notes__list">
            <li>The process exists. It lives in one person’s head, and that person is the founder.</li>
            <li>Nobody is confused about the goal. They are confused about who decides.</li>
            <li>“Your prices are too high” almost always means “I don’t understand what I’m getting.”</li>
            <li>Everyone already knows what is broken. There is no room in which saying it out loud is safe.</li>
          </ul>
        </div>
        <p class="field-notes__rule">That is not evidence, and I will not dress it up as evidence. It is where the instinct came from — and it is why the first thing I ask for is the raw conversations, not the summary.</p>
      </div>
    </div>
  </section>

  <section class="lenses-section zone-paper" id="boundary">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">Supporting business lenses</span><h2>I can work next to technical specialists without pretending to be one.</h2></div>
        <p>I define the business question, customer need, workflow, priority and success criteria. Designers, engineers and data specialists retain ownership of their craft.</p>
      </header>
      <div class="lens-list">
        {lenses.map(([title, copy], index) => (
          <article class="lens-row reveal">
            <span>{String(index + 1).padStart(2, '0')}</span><h3>{title}</h3><p>{copy}</p>
          </article>
        ))}
      </div>
      <div class="build-rule reveal">
        <span>Simplify</span><i>→</i><span>Automate</span><i>→</i><span>Build</span>
        <p>Building is the last option, not the first reaction. A clearer sentence, fewer fields or better ownership may solve more than a new feature.</p>
        
      </div>
    </div>
  </section>

  <section class="about-strip zone-night" id="about">
    <div class="wrap about-strip__grid">
      <div class="about-strip__quote reveal">
        <span class="eyebrow">Why I see problems this way</span>
        <blockquote>When the same question appears hundreds of times, I do not see hundreds of separate problems. I see one part of the system speaking through customers.</blockquote>
      </div>
      <div class="about-strip__copy reveal reveal-delay-1">
        {/* This paragraph used to be "my customer-facing foundation helps me
            connect customer behaviour, team performance, operating processes
            and wider business decisions" — four nouns in a coat. It said
            nothing that could be false, which is another way of saying it
            said nothing. */}
        <p>I learned this in the least glamorous way available: two years of being complained at, politely and impolitely, by people who were usually right.</p>
        <p>You cannot get this view from a dashboard. A dashboard tells you contacts are up eleven percent. It does not tell you that the same four words keep appearing, or that the customer is not actually angry about the delay — they are angry that nobody told them about it.</p>
        <p>So I start at the raw conversation and work backwards. By the time a problem reaches a meeting, everyone in the room is reading a summary of a summary.</p>
      </div>
    </div>
  </section>

  {/* The employer/business fork is gone. Asking a visitor to classify
      themselves before they have read anything was a decision they had no
      basis to make — and it split one evidence base into two weaker doors.
      One page, one close. */}
  <section class="routes-section zone-paper" id="talk">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">If any of this landed</span><h2>Tell me what is not working. I will tell you where it actually lives.</h2></div>
        <p>Whether you are hiring or you run the business, the first reply is the same: whether the problem fits what I do, and what evidence I would need to answer it properly. If it is not a fit, I will say so.</p>
      </header>

      <div class="close-actions reveal">
        <a class="btn btn--primary" href={withBase('/contact')}>Start a conversation <span class="btn__arrow" aria-hidden="true">→</span></a>
        <a class="btn" href={withBase('/work/formula4you')}>Read the Formula4You case <span class="btn__arrow" aria-hidden="true">→</span></a>
        <a class="btn" href={withBase('/assets/ahmed-hamdy-cv.pdf')}>Download the CV <span class="btn__arrow" aria-hidden="true">↓</span></a>
      </div>
      <p class="close-note reveal">Messages are read and answered personally. No response time is promised, because I will not promise one I cannot keep.</p>
    </div>
  </section>
</div>

<style>
  /* The bottom padding is not whitespace — it is clearance. `.hero::after` is
     the paper curve, and it rises ~85px above the hero's own bottom edge. The
     index has to end above that line or the curve eats the last three labels. */
  .hero { position: relative; min-height: 660px; padding: 6.5rem 0 7.9rem; overflow: hidden; color: var(--white); background: radial-gradient(circle at 84% 22%, rgba(121,183,255,.18), transparent 24rem), radial-gradient(circle at 7% 80%, rgba(72,224,187,.12), transparent 25rem), linear-gradient(135deg,#04151e 0%,#082632 63%,#0a303a 100%); }
  .hero::before { content: ''; position: absolute; inset: 0; opacity: .19; background-image: radial-gradient(rgba(255,255,255,.28) .7px, transparent .7px); background-size: 24px 24px; mask-image: radial-gradient(circle at 36% 36%,black,transparent 66%); }
  .hero::after { content: ''; position: absolute; z-index: 3; left: -5%; right: -5%; bottom: -95px; height: 180px; border-radius: 52% 48% 0 0 / 58% 65% 0 0; background: var(--paper); transform: rotate(-1.2deg); box-shadow: 0 -22px 45px rgba(0,0,0,.08); }
  /* The copy column was 1.02fr against a 450px minimum, which left the headline
     ~450px to hold display type — six cramped lines. The claim is the point of
     the hero; it gets the room. */
  .hero__grid { position: relative; z-index: 4; display: grid; grid-template-columns: minmax(0,1.25fr) minmax(360px,.75fr); align-items: center; gap: clamp(2.5rem,5vw,5rem); }
  .hero__copy h1 { max-width: 820px; margin-top: 1.25rem; font-size: clamp(2.35rem,1.5rem + 2.9vw,4.4rem); line-height: 1.02; letter-spacing: -.045em; }
  .hero__copy h1 span { position: relative; display: inline; color: var(--signal); }
  .hero__copy h1 span::after { content: ''; position: absolute; left: 1%; right: -3%; bottom: -.12em; height: 12px; border-radius: 50%; border-top: 3px solid var(--coral); transform: rotate(-1.2deg); }
  .hero__lede { max-width: 650px; margin-top: 1.7rem; color: rgba(255,255,255,.68); font-size: clamp(1rem,.96rem + .3vw,1.2rem); }
  .hero__depth { max-width: 660px; margin-top: 1.3rem; color: rgba(255,255,255,.45); font: 750 .7rem/1.7 var(--font-head); letter-spacing: .08em; text-transform: uppercase; }
  .hero__actions { margin-top: 2rem; }
  /* The page's shape, on the first screen. Quiet enough not to compete with
     the claim; complete enough to answer "how much is here?" */
  .hero__index { display: flex; flex-wrap: wrap; gap: 0 1.6rem; margin-top: 1.6rem; padding-top: 1.2rem; border-top: 1px solid rgba(255,255,255,.12); }
  .hero__index a { display: flex; align-items: baseline; gap: .5rem; padding: .5rem 0; color: rgba(255,255,255,.62); text-decoration: none; font: 700 .72rem var(--font-head); transition: color var(--dur-fast) var(--ease); }
  .hero__index a:hover { color: var(--signal); }
  .hero__index span { color: var(--signal); font-size: .58rem; letter-spacing: .08em; font-variant-numeric: tabular-nums; }
  .system-lens { position: relative; min-height: 430px; }
  .lens-orbit { position: absolute; border: 1px solid rgba(255,255,255,.14); border-radius: 48% 52% 57% 43% / 54% 44% 56% 46%; animation: orbit-shape 11s ease-in-out infinite alternate; }
  .lens-orbit--one { inset: 20px 0 5px 5px; transform: rotate(12deg); }
  .lens-orbit--two { inset: 76px 55px 58px 50px; border-color: rgba(72,224,187,.25); transform: rotate(-17deg); animation-delay: -4s; }
  .lens-orbit--three { inset: 132px 115px 108px 105px; border-style: dashed; border-color: rgba(121,183,255,.3); animation-delay: -7s; }
  .portrait-frame { position: absolute; z-index: 4; left: 50%; top: 48%; width: 290px; height: 380px; overflow: hidden; border: 6px solid rgba(255,255,255,.12); border-radius: 28px 12px 36px 16px; background: var(--night-soft); box-shadow: 0 35px 90px rgba(0,0,0,.45), inset 0 0 30px rgba(255,255,255,.08); transform: translate(-50%,-50%) rotate(1.2deg); }
  .portrait-frame img { width: 100%; height: 100%; object-fit: cover; object-position: center 17%; filter: saturate(.84) contrast(1.04); }
  .portrait-frame span { position: absolute; left: 12px; right: 12px; bottom: 12px; padding: .7rem .9rem; color: rgba(255,255,255,.72); border: 1px solid rgba(255,255,255,.14); border-radius: 14px 6px 16px 8px; background: rgba(4,21,30,.78); backdrop-filter: blur(10px); font: 750 .58rem var(--font-head); letter-spacing: .08em; text-transform: uppercase; }
  .lens-core { position: absolute; z-index: 6; left: 70%; top: 67%; width: 104px; height: 104px; display: grid; place-items: center; color: var(--ink); border-radius: 48% 52% 43% 57% / 58% 41% 59% 42%; background: var(--acid); box-shadow: 0 18px 45px rgba(0,0,0,.32),0 0 0 13px rgba(201,243,111,.08); transform: translate(-50%,-50%); font: 850 .58rem var(--font-head); letter-spacing: .09em; text-transform: uppercase; animation: core-pulse 3.5s ease-in-out infinite; }
  .orbit-node { position: absolute; z-index: 7; display: flex; align-items: center; gap: .55rem; padding: .75rem .95rem; color: rgba(255,255,255,.82); border: 1px solid rgba(255,255,255,.16); border-radius: var(--shape-pill); background: rgba(6,24,34,.74); box-shadow: 0 18px 36px rgba(0,0,0,.28); backdrop-filter: blur(15px); font: 760 .63rem var(--font-head); }
  .orbit-node::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--node,var(--signal)); box-shadow: 0 0 15px var(--node,var(--signal)); }
  .orbit-node--support { left: 0; top: 20%; }
  .orbit-node--sales { --node: var(--coral); right: -2%; top: 29%; }
  .orbit-node--ops { --node: var(--sky); left: 7%; bottom: 6%; }
  .orbit-node--customer { --node: var(--violet); right: 1%; bottom: 10%; }
  .journey { position: relative; color: var(--ink); background: var(--paper); }
  .journey__spine { position: absolute; z-index: 2; inset: 0; width: 100%; height: 100%; pointer-events: none; opacity: .55; }
  .journey__glow { fill: none; stroke: rgba(17,125,108,.07); stroke-width: 55; stroke-linecap: round; }
  .journey__line { fill: none; stroke: url(#journey-gradient); stroke-width: 3; stroke-linecap: round; stroke-dasharray: 8 14; animation: dash 22s linear infinite; }
  .journey__spine circle { fill: var(--paper); stroke-width: 3; }
  .signal-section, .impact-section { position: relative; z-index: 3; padding: 2.2rem 0 2.8rem; }
  .scenario-label { display: inline-block; margin-top: .9rem; color: #5c6e75; /* not --slate-soft: that token is 3.47 here. It stays as-is because the night zones need it light. */ font: 750 .62rem var(--font-head); letter-spacing: .1em; text-transform: uppercase; }
  /* THE FOUR-ACTOR DIAGRAM — used twice: what each team sees, then what each
     team felt. Both share this geometry on purpose. It is the same four people
     before and after, and the rhyme is the argument.

     The islands used to be absolutely positioned at fixed percentages, 265px
     wide and capped at 150px tall. That is room for roughly twenty words — so
     every card said twenty words, in the same shape, at the same temperature.
     The layout was writing the copy, and it was writing it badly. Real
     sentences of unequal length overflowed and the cards landed on top of each
     other.

     Now: a 2×2 grid that grows with whatever is written in it. The inner
     padding is load-bearing, not decoration — the core sits exactly on the grid
     intersection, so text has to be pushed clear of it or the two collide. */
  .signal-map, .impact-system { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; padding: 0 2rem; align-items: start; }
  /* The corner radii are px, not percentages, and that is the whole fix.
     Percentages scale with the box, so every reflow moved the corner and the
     text fell outside somewhere new — 1440 passed while 390 failed, then 390
     passed and 560 failed. Fixed px corners cut a known amount, so one padding
     value clears them at every width instead of at the width I screenshotted. */
  .signal-island { position: relative; z-index: 3; min-height: 190px; padding: 3rem 4.25rem; border: 1px solid var(--paper-line); background: rgba(255,255,255,.77); box-shadow: var(--shadow-soft); backdrop-filter: blur(12px); }
  .signal-island span { color: var(--signal-deep); font: 850 .58rem var(--font-head); letter-spacing: .14em; text-transform: uppercase; }
  .signal-island h3 { margin: 1.5rem 0 .65rem; font-size: 1.35rem; }
  .signal-island p { color: var(--ink-soft); font-size: .84rem; line-height: 1.6; }
  .signal-island--support { border-radius: 148px 58px 112px 92px / 90px 62px 46px 86px; }
  .signal-island--sales { border-radius: 56px 146px 96px 116px / 60px 88px 84px 48px; }
  .signal-island--sales span { color: #c84b38; }
  .signal-island--ops { border-radius: 104px 92px 54px 150px / 48px 84px 90px 62px; }
  .signal-island--ops span { color: #286cb5; }
  .signal-island--lead { color: var(--white); border-color: transparent; border-radius: 92px 118px 144px 56px / 86px 46px 62px 90px; background: var(--night-soft); box-shadow: var(--shadow-deep); }
  .signal-island--lead span { color: var(--acid); }
  .signal-island--lead p { color: rgba(255,255,255,.6); }
  .signal-map__core { position: absolute; z-index: 5; left: 50%; top: 50%; width: 180px; height: 180px; display: grid; place-content: center; padding: 1.4rem; text-align: center; border-radius: 50%; background: var(--acid); box-shadow: 0 24px 58px rgba(77,105,27,.2),0 0 0 18px rgba(201,243,111,.15); transform: translate(-50%,-50%); }
  .signal-map__core strong { font: 800 1rem/1.25 var(--font-head); }
  .signal-map__core small { margin-top: .5rem; color: rgba(7,26,36,.72); font: 800 .55rem var(--font-head); letter-spacing: .12em; text-transform: uppercase; }
  .decision-section { position: relative; z-index: 4; padding: 1.4rem 0; background: transparent; }
  .decision-shell { padding: clamp(2.6rem,6vw,5rem); border-radius: 72px 22px 82px 30px; background: radial-gradient(circle at 8% 45%,rgba(72,224,187,.12),transparent 20rem),radial-gradient(circle at 90% 80%,rgba(121,183,255,.13),transparent 23rem),var(--night); box-shadow: var(--shadow-deep); }
  .decision-path { position: relative; display: grid; grid-template-columns: repeat(6,1fr); gap: 1rem; }
  .decision-path::before { content: ''; position: absolute; left: 3%; right: 3%; top: 21px; height: 2px; background: linear-gradient(90deg,var(--coral),var(--violet),var(--acid),var(--sky),var(--signal)); }
  .decision-path li { position: relative; z-index: 2; padding-right: .7rem; }
  .decision-path span { width: 43px; height: 43px; display: grid; place-items: center; margin-bottom: 1.25rem; color: var(--ink); border-radius: 52% 48% 40% 60% / 45% 58% 42% 55%; background: var(--signal); box-shadow: 0 0 0 8px rgba(255,255,255,.04); font: 850 .62rem var(--font-head); }
  .decision-path li:nth-child(1) span { background: var(--coral); }
  .decision-path li:nth-child(2) span { background: var(--violet); }
  .decision-path li:nth-child(3) span { background: var(--acid); }
  .decision-path li:nth-child(4) span { background: var(--sky); }
  .decision-path li:nth-child(6) span { background: var(--acid); }
  .decision-path h3 { font-size: 1.05rem; }
  .decision-path p { margin-top: .6rem; color: var(--slate); font-size: .74rem; line-height: 1.6; }
  .decision-note { max-width: 900px; margin: 2.5rem auto 0; padding: 1.2rem 1.5rem; color: var(--ink); border-radius: 28px 9px 30px 12px; background: var(--acid); text-align: center; font-size: .86rem; }
  .impact-section { padding-top: 2.6rem; padding-bottom: 3rem; }
  .impact-petal { position: relative; min-height: 190px; padding: 3rem 4.25rem; box-shadow: var(--shadow-soft); }
  .impact-petal span { color: rgba(7,26,36,.68); font: 850 .58rem var(--font-head); letter-spacing: .14em; text-transform: uppercase; }
  .impact-petal h3 { margin: 2rem 0 .7rem; font-size: 1.65rem; }
  .impact-petal p { color: var(--ink-soft); font-size: .84rem; }
  .impact-petal--support { border-radius: 150px 60px 108px 94px / 88px 64px 44px 90px; background: var(--signal-soft); }
  .impact-petal--sales { border-radius: 58px 148px 92px 118px / 62px 90px 86px 46px; background: var(--coral-soft); }
  .impact-petal--ops { border-radius: 108px 90px 56px 146px / 46px 86px 88px 64px; background: var(--sky-soft); }
  .impact-petal--lead { border-radius: 94px 116px 150px 58px / 88px 44px 64px 92px; background: #ece4ff; }
  .impact-core { position: absolute; z-index: 4; left: 50%; top: 50%; width: 196px; height: 196px; display: grid; place-content: center; padding: 1.5rem; color: var(--white); border-radius: 52% 48% 55% 45% / 43% 60% 40% 57%; background: var(--night-soft); box-shadow: 0 25px 60px rgba(7,26,36,.28),0 0 0 17px rgba(7,26,36,.04); text-align: center; transform: translate(-50%,-50%); }
  .impact-core span { color: var(--signal); font: 850 .55rem var(--font-head); letter-spacing: .13em; text-transform: uppercase; }
  .impact-core strong { margin-top: .55rem; font: 780 .93rem/1.32 var(--font-head); }

  /* Clearing the core, take two. Padding the text away from it worked but
     stretched every card into a flat lozenge — the organic radii are
     percentages, so a wide short box renders as an ellipse and the islands
     stopped reading as islands.

     Instead the cards keep their proportions and move outward, which opens a
     gap down the middle for the core to live in. The width is derived, not
     guessed: each card gives up 136px so the pair leaves ≥272px between them,
     and the core is 196px. It holds at every column width rather than at the
     one I happened to screenshot. */
  .signal-island, .impact-petal { max-width: calc(100% - 8.5rem); }
  .signal-island--support, .signal-island--ops,
  .impact-petal--support, .impact-petal--ops { justify-self: start; }
  .signal-island--sales, .signal-island--lead,
  .impact-petal--sales, .impact-petal--lead { justify-self: end; }
  .capability-section { padding: 3rem 0 3.5rem; }
  .capability-list { max-width: 1000px; }

  /* Body of an opened capability. The accent colour is the only thing that
     changes per capability — the structure stays identical, because four
     differently-shaped panels would be decoration, not information. */
  .cap-body { --cap: var(--signal-deep); }
  .cap-body--sky { --cap: #2f6fb0; }
  .cap-body--violet { --cap: #6b55b8; }
  .cap-body--coral { --cap: #c0492f; }
  .cap-body__k {
    margin: 2rem 0 .9rem !important;
    color: var(--cap) !important;
    font: 850 .6rem var(--font-head); letter-spacing: .13em; text-transform: uppercase;
  }
  .cap-body__list { display: grid; gap: .6rem; margin: 0 0 1.6rem; padding: 0; list-style: none; }
  .cap-body__list li {
    position: relative; padding-left: 1.1rem;
    color: var(--ink-soft); font-size: .88rem; line-height: 1.6;
  }
  .cap-body__list li::before {
    content: ''; position: absolute; left: 0; top: .62em;
    width: .4rem; height: .4rem; border-radius: 50%; background: var(--cap);
  }
  .cap-body__proof {
    margin: 0 !important; padding-top: 1rem;
    border-top: 1px solid var(--paper-line);
    color: var(--slate-soft) !important;
    font: 750 .68rem var(--font-head) !important; letter-spacing: .04em;
  }
  .capability-row { --cap: var(--signal); display: grid; grid-template-columns: minmax(280px,.8fr) minmax(300px,1fr) minmax(220px,.72fr); gap: clamp(1.5rem,4vw,3.5rem); align-items: start; padding: 2rem 0; border-bottom: 1px solid var(--paper-line); }
  .capability-row--sky { --cap: #458bd8; }
  .capability-row--violet { --cap: #8069cc; }
  .capability-row--coral { --cap: #cb503a; }
  .capability-row__title > span { color: var(--cap); font: 850 .62rem var(--font-head); letter-spacing: .12em; }
  .capability-row h3 { margin-top: .5rem; font-size: 1.4rem; }
  .capability-row small { display: block; margin-top: .65rem; color: var(--slate-soft); font-size: .68rem; }
  .capability-row__observation { color: var(--ink-soft); font-size: .9rem; }
  .capability-row ul { display: grid; gap: .35rem; }
  .capability-row li { position: relative; padding-left: 1rem; color: var(--ink-soft); font-size: .76rem; }
  .capability-row li::before { content: ''; position: absolute; left: 0; top: .65em; width: .38rem; height: .38rem; border-radius: 50%; background: var(--cap); }
  .proof-section { position: relative; padding: 4.2rem 0 4rem; overflow: hidden; }
  .proof-section::before { content: ''; position: absolute; left: -4%; right: -4%; top: -78px; height: 128px; border-radius: 0 0 52% 48%; background: var(--paper); }
  .proof-grid { display: grid; grid-template-columns: 1.08fr .92fr; gap: 1.8rem; align-items: stretch; }
  .alpha-proof { padding: clamp(2rem,4.5vw,3.8rem); color: var(--ink); border-radius: 74px 24px 84px 28px; background: var(--paper); box-shadow: var(--shadow-deep); }
  .alpha-proof h3 { max-width: 650px; margin: 1.4rem 0 1rem; font-size: clamp(2rem,3.3vw,3.4rem); }
  .alpha-proof > p { color: var(--ink-soft); }
  .alpha-proof__flow { display: flex; align-items: center; gap: .75rem; margin: 2rem 0; color: var(--signal-deep); font: 850 .62rem var(--font-head); letter-spacing: .08em; text-transform: uppercase; }
  .alpha-proof__flow i { flex: 1; min-width: 20px; height: 1px; background: var(--paper-line-strong); }
  .alpha-proof ul { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem 1.4rem; }
  .alpha-proof li { position: relative; padding-left: 1rem; color: var(--ink-soft); font-size: .78rem; }
  .alpha-proof li::before { content: ''; position: absolute; left: 0; top: .6em; width: .4rem; height: .4rem; border-radius: 50%; background: var(--signal-deep); }
  .alpha-proof > a { display: inline-block; margin-top: 1.8rem; color: var(--signal-deep); font: 850 .82rem var(--font-head); text-decoration: none; }
  .formula-proof { overflow: hidden; border: 1px solid var(--hairline); border-radius: 26px 72px 30px 82px; background: rgba(255,255,255,.055); box-shadow: var(--shadow-deep); }
  .formula-proof__image { position: relative; height: 290px; overflow: hidden; }
  .formula-proof__image::after { content: ''; position: absolute; inset: auto 0 0; height: 55%; background: linear-gradient(transparent,var(--night-soft)); }
  .formula-proof__image img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
  .formula-proof__copy { padding: 2rem; }
  .formula-proof h3 { margin: 1rem 0 .75rem; font-size: 1.9rem; }
  .formula-proof p { margin-bottom: .8rem; color: var(--slate); font-size: .86rem; line-height: 1.62; }
  .formula-proof__role { margin: 1rem 0 1.5rem; color: var(--signal) !important; font: 800 .7rem var(--font-head); }
  .formula-proof .btn { min-height: 42px; font-size: .72rem; }
  .close-actions { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 2.5rem; }
  .close-note { max-width: 60ch; margin-top: 1.8rem; color: var(--slate-soft); font-size: .82rem; }
  .alpha-note { margin-top: 1.6rem !important; padding: 1rem 1.2rem; border-left: 3px solid var(--signal-deep); background: rgba(17,125,108,.07); border-radius: 0 14px 14px 0; font-size: .8rem !important; }

  /* Field notes — deliberately the plainest block on the page. It is the one
     section with nothing to show, so dressing it up would undercut the point. */
  .field-notes { margin-top: 1.8rem; padding: clamp(1.6rem,3vw,2.6rem); border: 1px dashed var(--hairline-strong); border-radius: 30px 66px 26px 70px; background: rgba(255,255,255,.03); }
  .field-notes h3 { max-width: 30ch; margin: .9rem 0 1.6rem; color: var(--chalk); font-size: clamp(1.4rem,2.2vw,2.05rem); }
  .field-notes__grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 1.4rem 2.6rem; align-items: start; }
  .field-notes__say p { margin-bottom: .9rem; color: var(--slate); font-size: .87rem; line-height: 1.68; }
  .field-notes__say p:last-child { margin-bottom: 0; }
  .field-notes__list { display: grid; gap: .7rem; }
  .field-notes__list li { position: relative; padding-left: 1.35rem; color: var(--chalk); font-size: .85rem; line-height: 1.55; }
  .field-notes__list li::before { content: ''; position: absolute; left: 0; top: .62em; width: .42rem; height: .42rem; border-radius: 50%; background: var(--acid); }
  .field-notes__rule { max-width: 78ch; margin-top: 1.7rem; padding-top: 1.3rem; border-top: 1px solid var(--hairline); color: var(--slate-soft); font-size: .82rem; line-height: 1.6; }
  @media (max-width: 780px) { .field-notes__grid { grid-template-columns: 1fr; } }
  .lenses-section { padding: 3.6rem 0; }
  .lens-list { border-top: 1px solid var(--paper-line); }
  .lens-row { display: grid; grid-template-columns: 55px minmax(250px,.72fr) minmax(320px,1fr); gap: 1.5rem; padding: 1.4rem 0; border-bottom: 1px solid var(--paper-line); align-items: baseline; }
  .lens-row > span { color: var(--signal-deep); font: 850 .62rem var(--font-head); }
  .lens-row h3 { font-size: 1.1rem; }
  .lens-row p { color: var(--ink-soft); font-size: .84rem; }
  .build-rule { display: grid; grid-template-columns: auto auto auto auto auto minmax(260px,1fr) auto; align-items: center; gap: 1rem; margin-top: 3rem; padding: 1.5rem 1.8rem; color: var(--white); border-radius: 36px 13px 40px 16px; background: var(--night-soft); box-shadow: var(--shadow-soft); }
  .build-rule > span { color: var(--acid); font: 850 .8rem var(--font-head); }
  .build-rule i { color: var(--slate); font-style: normal; }
  .build-rule p { color: var(--slate); font-size: .78rem; }
  .build-rule a { color: var(--signal); font: 850 .72rem var(--font-head); text-decoration: none; white-space: nowrap; }
  .about-strip { padding: 6rem 0; background: radial-gradient(circle at 10% 40%,rgba(187,165,255,.13),transparent 22rem),var(--night); }
  .about-strip__grid { display: grid; grid-template-columns: 1.2fr .65fr; gap: clamp(3rem,9vw,8rem); align-items: center; }
  .about-strip blockquote { margin-top: 1.4rem; font: italic clamp(2rem,3.5vw,3.8rem)/1.15 var(--font-serif); letter-spacing: -.025em; }
  .about-strip__copy p { margin-bottom: .95rem; color: var(--slate); line-height: 1.7; }
  .about-strip__copy p:last-child { margin-bottom: 0; color: var(--chalk); }
  .about-strip__copy a { display: inline-block; margin-top: 1.4rem; color: var(--signal); font: 850 .82rem var(--font-head); text-decoration: none; }
  .routes-section { padding: 3.4rem 0 4.5rem; }
  .route-fork { position: relative; display: grid; grid-template-columns: 1fr 135px 1fr; gap: 1.2rem; align-items: center; }
  .route-card { min-height: 310px; display: flex; flex-direction: column; justify-content: center; padding: clamp(2rem,4vw,3.3rem); color: var(--ink); text-decoration: none; box-shadow: var(--shadow-soft); transition: transform var(--dur-mid) var(--ease); }
