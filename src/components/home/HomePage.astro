    padding: clamp(1.5rem, 3.2vw, 2.5rem) 0;
    cursor: pointer; list-style: none;
  }
  .case__head::-webkit-details-marker { display: none; }
  .case__head:focus-visible { outline: 2px solid var(--signal-deep); outline-offset: 4px; border-radius: 6px; }
  .case__n { flex: none; color: var(--signal-deep); font: 850 clamp(1.7rem, 1.1rem + 1.7vw, 2.7rem)/1 var(--font-head); letter-spacing: -.03em; font-variant-numeric: tabular-nums; }
  .case__titles { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .4rem; }
  .case__t { color: var(--ink); font: 750 clamp(1.05rem, .9rem + .7vw, 1.55rem)/1.25 var(--font-head); letter-spacing: -.02em; text-wrap: balance; }
  .case__ctx { color: #5c6e75; font: 800 .6rem var(--font-head); letter-spacing: .1em; text-transform: uppercase; }
  .case__open { flex: none; color: #5c6e75; font: 800 .64rem var(--font-head); letter-spacing: .12em; text-transform: uppercase; transition: color var(--dur-fast) var(--ease); }
  .case[open] .case__open { color: var(--signal-deep); }
  .case__chev { flex: none; display: grid; place-items: center; width: 42px; height: 42px; color: var(--ink); border: 1px solid var(--paper-line-strong); border-radius: 50%; transition: transform var(--dur-mid) var(--ease), border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease); }
  .case__head:hover .case__chev { border-color: var(--signal-deep); background: var(--signal-soft); }
  .case[open] .case__chev { transform: rotate(180deg); }
  @media (max-width: 640px) { .case__open { display: none; } .case__head { gap: 1rem; } }
  @media (prefers-reduced-motion: reduce) { .case__chev, .case__open { transition: none; } }

  .hero { --hero-pad-top: 5.4rem; --hero-pad-bottom: 5.7rem; position: relative; min-height: 660px; padding: var(--hero-pad-top) 0 var(--hero-pad-bottom); overflow: hidden; color: var(--white); background: radial-gradient(circle at 84% 22%, rgba(121,183,255,.18), transparent 24rem), radial-gradient(circle at 7% 80%, rgba(72,224,187,.12), transparent 25rem), linear-gradient(135deg,#04151e 0%,#082632 63%,#0a303a 100%); }
  .hero::before { content: ''; position: absolute; inset: 0; opacity: .19; background-image: radial-gradient(rgba(255,255,255,.28) .7px, transparent .7px); background-size: 24px 24px; mask-image: radial-gradient(circle at 36% 36%,black,transparent 66%); }
  .hero::after { content: ''; position: absolute; z-index: 3; left: -5%; right: -5%; bottom: -95px; height: 180px; border-radius: 52% 48% 0 0 / 58% 65% 0 0; background: var(--paper); transform: rotate(-1.2deg); box-shadow: 0 -22px 45px rgba(0,0,0,.08); }
  /* The copy column was 1.02fr against a 450px minimum, which left the headline
     ~450px to hold display type — six cramped lines. The claim is the point of
     the hero; it gets the room. */
  .hero__grid { position: relative; z-index: 4; display: grid; grid-template-columns: minmax(0,1.1fr) minmax(340px,.9fr); align-items: center; gap: clamp(2rem,4vw,4rem); }
  .hero__copy h1 { max-width: 820px; margin-top: 1.25rem; font-size: clamp(2.35rem,1.5rem + 2.9vw,4.4rem); line-height: 1.02; letter-spacing: -.045em; }
  .hero__copy h1 span { position: relative; display: inline; color: var(--signal); }
  .hero__copy h1 span::after { content: ''; position: absolute; left: 1%; right: -3%; bottom: -.12em; height: 12px; border-radius: 50%; border-top: 3px solid var(--coral); transform: rotate(-1.2deg); }
  .hero__lede { max-width: 650px; margin-top: 1.35rem; color: rgba(255,255,255,.68); font-size: clamp(1rem,.96rem + .3vw,1.2rem); }
  /* The lede is two paragraphs now — the second one is the record. */
  .hero__lede + .hero__lede { margin-top: .9rem; }
  .hero__depth { max-width: 660px; margin-top: 1rem; color: rgba(255,255,255,.45); font: 750 .7rem/1.7 var(--font-head); letter-spacing: .08em; text-transform: uppercase; }
  /* The free line. A pill, not a banner — it should read as a fact stated in
     passing, not as an offer being pushed. */
  .hero__free { display: inline-flex; align-items: center; gap: .55rem; margin-top: 1rem; padding: .5rem .95rem; color: var(--chalk); border: 1px solid rgba(72,224,187,.34); border-radius: var(--shape-pill); background: rgba(72,224,187,.09); font: 700 .74rem var(--font-head); }
  .hero__free span { width: 6px; height: 6px; flex: none; border-radius: 50%; background: var(--acid); box-shadow: 0 0 0 3px rgba(201,243,111,.18); }
  .close-free { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--paper-line); color: var(--ink-soft); font-size: .88rem; line-height: 1.68; }
  .close-free strong { color: var(--ink); font-weight: 750; }
  .hero__actions { margin-top: 1.5rem; }
  /* The page's shape, on the first screen. Quiet enough not to compete with
     the claim; complete enough to answer "how much is here?" */
  .system-lens { position: relative; align-self: stretch; min-height: 500px; }
  /* Ambient light behind him, so he is lit BY the hero rather than pasted onto
     it. Blurred and low-opacity — if you can see where it ends, it is too strong. */
  .lens-glow { position: absolute; z-index: 1; inset: 2% 4% 22% 8%; border-radius: 50%; background: radial-gradient(circle at 50% 36%, rgba(121,183,255,.22), rgba(72,224,187,.11) 46%, transparent 72%); filter: blur(22px); }

  /* Bleeds past the grid cell by exactly the hero's padding, so it reaches the
     hero's real top and bottom edges; the hero clips it.

     A correction to what this comment used to claim: z-index 2 does NOT put
     this under the paper curve. .hero__grid is position:relative with z-index 4,
     which makes it a stacking context, so everything in here paints at 4 —
     above .hero::after at 3. What actually ends the figure is the mask, and it
     has to end BOTH layers. Masking only the image left the ::after colour wash
     painting a dark smudge across the cream curve. */
  .hero-figure { position: absolute; z-index: 2; top: calc(-1 * var(--hero-pad-top)); bottom: calc(-1 * var(--hero-pad-bottom)); left: -7%; right: -5%; }
  /* Two nested masks rather than mask-composite: intersect, which still needs a
     different keyword in WebKit. The wrapper takes the vignette, the image takes
     the vertical fade, and nesting composites them. */
  /* The ellipse has to reach transparent BEFORE the box edge, not at it. The
     first attempt ended at 100% and left roughly half opacity on the right
     edge, which drew exactly the straight photo boundary the mask exists to
     remove. A mid stop does the rest of the work: the lobby behind him thins
     out instead of tapering to a line. */
  .hero-figure { -webkit-mask-image: radial-gradient(ellipse 58% 72% at 54% 40%, #000 38%, rgba(0,0,0,.55) 66%, transparent 88%); mask-image: radial-gradient(ellipse 58% 72% at 54% 40%, #000 38%, rgba(0,0,0,.55) 66%, transparent 88%); }
  /* The lobby he was photographed in is warm, bright and high-key; the hero is
     none of those. Desaturating and cooling is what stops the picture reading as
     a window cut into the page. */
  .hero-figure img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 10%; filter: saturate(.6) contrast(1.07) brightness(.84) hue-rotate(-8deg); -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 10%, #000 58%, transparent 94%); mask-image: linear-gradient(180deg, transparent 0%, #000 10%, #000 58%, transparent 94%); }
  /* A wash in the hero's own two colours over the graded image — this is the
     last step that makes the two backgrounds agree. */
  .hero-figure::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(4,21,30,.58) 0%, rgba(4,21,30,.04) 24%, rgba(8,38,50,.3) 60%, rgba(4,21,30,.95) 100%), linear-gradient(90deg, rgba(4,21,30,.6) 0%, transparent 30%, transparent 72%, rgba(4,21,30,.45) 100%); -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 10%, #000 58%, transparent 94%); mask-image: linear-gradient(180deg, transparent 0%, #000 10%, #000 58%, transparent 94%); }

  /* One line, not four. At 15ch this wrapped into a narrow column that read as
     a fifth floating chip competing with the four signals, which is one too
     many things to look at. On a single line it reads as what it is: the label
     for the group. */
  /* Same glass as the signals, one step quieter — it labels the group rather
     than being a fifth member of it. */
  .hero-figure__tag { position: absolute; z-index: 6; left: -6%; bottom: 7%; white-space: nowrap; padding: .6rem 1rem; color: rgba(255,255,255,.7); border: 1px solid transparent; border-radius: var(--shape-pill); background: linear-gradient(160deg, rgba(9,30,40,.8), rgba(4,19,27,.9)) padding-box, linear-gradient(140deg, rgba(255,255,255,.24), rgba(255,255,255,.03) 50%, rgba(255,255,255,.13)) border-box; box-shadow: 0 14px 30px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.07); backdrop-filter: blur(20px) saturate(1.25); font: 700 .54rem var(--font-head); letter-spacing: .13em; text-transform: uppercase; }
  /* The labels are the only furniture floating over the photograph, so they
     carry the whole impression of care. A flat 1px border and a solid fill read
     as a UI chip dropped on top of a picture; the difference is all in the edge.
     Three things do it:

     · a hairline that is a GRADIENT rather than a flat colour, so it catches
       light along one side the way a real bevel does. padding-box/border-box is
       the only way to get a gradient border without an extra wrapper element.
     · a lit top edge (the inset highlight) plus a tighter, deeper shadow, which
       together read as a raised piece of glass rather than a flat panel.
     · uppercase at small size with wide tracking — a label on an instrument,
       not a button. Heavier blur and a touch of saturate make the glass real. */
  .orbit-node { position: absolute; z-index: 7; display: flex; align-items: center; gap: .6rem; padding: .64rem 1.05rem .64rem .9rem; color: rgba(255,255,255,.92); border: 1px solid transparent; border-radius: var(--shape-pill); background: linear-gradient(160deg, rgba(10,34,45,.86), rgba(4,19,27,.93)) padding-box, linear-gradient(140deg, rgba(255,255,255,.36), rgba(255,255,255,.05) 46%, rgba(255,255,255,.2)) border-box; box-shadow: 0 16px 34px rgba(0,0,0,.46), inset 0 1px 0 rgba(255,255,255,.11); backdrop-filter: blur(20px) saturate(1.35); font: 700 .58rem var(--font-head); letter-spacing: .1em; text-transform: uppercase; }
  .orbit-node::before { content: ''; width: 6px; height: 6px; flex: none; border-radius: 50%; background: var(--node,var(--signal)); box-shadow: 0 0 12px var(--node,var(--signal)), 0 0 0 3px rgba(255,255,255,.07); }
  .orbit-node--support { left: -4%; top: 11%; }
  .orbit-node--sales { --node: var(--coral); right: -3%; top: 30%; }
  .orbit-node--ops { --node: var(--sky); left: -6%; bottom: 34%; }
  .orbit-node--customer { --node: var(--violet); right: -1%; bottom: 9%; }
  .journey { position: relative; color: var(--ink); background: var(--paper); }
  .journey__spine { position: absolute; z-index: 2; inset: 0; width: 100%; height: 100%; pointer-events: none; opacity: .55; }
  .journey__glow { fill: none; stroke: rgba(17,125,108,.07); stroke-width: 55; stroke-linecap: round; }
  .journey__line { fill: none; stroke: url(#journey-gradient); stroke-width: 3; stroke-linecap: round; stroke-dasharray: 8 14; animation: dash 22s linear infinite; }
  .journey__spine circle { fill: var(--paper); stroke-width: 3; }
  /* THE CASE — the spine of the page. Nine disclosures, and the collapsed
     titles alone tell the whole story: "the answer was not faster replies" →
     "repeat contact is the tell" → "the article was a patch" → … → "Completed
     did not mean completed". A reader who never opens one has still read it. */
  .case-section { position: relative; z-index: 4; padding: 1.4rem 0; background: transparent; }
  .case-shell { padding: clamp(2.2rem,5vw,4rem) clamp(1.6rem,4vw,3.4rem); border-radius: 72px 22px 82px 30px; background: radial-gradient(circle at 8% 12%,rgba(72,224,187,.12),transparent 22rem),radial-gradient(circle at 92% 84%,rgba(121,183,255,.13),transparent 24rem),var(--night); box-shadow: var(--shadow-deep); }
  .case-shell .section-head { margin-bottom: 1.6rem; }
  .case-list { margin-top: .5rem; }

  .signal-section, .impact-section { position: relative; z-index: 3; padding: 2.2rem 0 2.8rem; }
  .scenario-label { display: inline-block; margin-top: .9rem; color: #5c6e75; /* not --slate-soft: that token is 3.47 here. It stays as-is because the night zones need it light. */ font: 750 .62rem var(--font-head); letter-spacing: .1em; text-transform: uppercase; }
  /* THE FOUR-ACTOR DIAGRAM — used twice: what each team sees, then what each
     team felt. Both share this geometry on purpose. It is the same four people
     before and after, and the rhyme is the argument.

     The islands used to be absolutely positioned at fixed percentages, 265px
     wide and capped at 150px tall. That is room for roughly twenty words — so
     every card said twenty words, in the same shape, at the same temperature.
     The layout was writing the copy, and it was writing it badly. Real
     sentences of unequal length overflowed and the cards landed on top of each
     other.

     Now: a 2×2 grid that grows with whatever is written in it. The inner
     padding is load-bearing, not decoration — the core sits exactly on the grid
     intersection, so text has to be pushed clear of it or the two collide. */
  .signal-map, .impact-system { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; padding: 0 2rem; align-items: start; }
  /* The corner radii are px, not percentages, and that is the whole fix.
     Percentages scale with the box, so every reflow moved the corner and the
     text fell outside somewhere new — 1440 passed while 390 failed, then 390
     passed and 560 failed. Fixed px corners cut a known amount, so one padding
     value clears them at every width instead of at the width I screenshotted. */
  /* Reading order. Four cards in a 2x2 with a core in the middle give the eye
     no entry point — it is the one thing colour cannot encode, because colour
     already means "which department". */
  .signal-island > span, .impact-petal > span { display: flex; align-items: center; gap: .5rem; }
  .isle__n {
    display: flex; align-items: center; gap: .5rem; flex: none;
    font-style: normal; font-variant-numeric: tabular-nums; letter-spacing: .04em;
  }
  .isle__n::after {
    content: ''; display: block; width: 15px; height: 1px;
    background: currentColor; opacity: .45;
  }

  .signal-island { position: relative; z-index: 3; min-height: 190px; padding: 3rem 4.25rem; border: 1px solid var(--paper-line); background: rgba(255,255,255,.77); box-shadow: var(--shadow-soft); backdrop-filter: blur(12px); }
  .signal-island span { color: var(--signal-deep); font: 850 .58rem var(--font-head); letter-spacing: .14em; text-transform: uppercase; }
  .signal-island h3 { margin: 1.5rem 0 .65rem; font-size: 1.35rem; }
  .signal-island p { color: var(--ink-soft); font-size: .84rem; line-height: 1.6; }
  .signal-island--support { border-radius: 148px 58px 112px 92px / 90px 62px 46px 86px; }
  .signal-island--sales { border-radius: 56px 146px 96px 116px / 60px 88px 84px 48px; }
  .signal-island--sales span { color: #c84b38; }
  .signal-island--ops { border-radius: 104px 92px 54px 150px / 48px 84px 90px 62px; }
  .signal-island--ops span { color: #286cb5; }
  .signal-island--lead { color: var(--white); border-color: transparent; border-radius: 92px 118px 144px 56px / 86px 46px 62px 90px; background: var(--night-soft); box-shadow: var(--shadow-deep); }
  .signal-island--lead span { color: var(--acid); }
  .signal-island--lead p { color: rgba(255,255,255,.6); }
  .signal-map__core { position: absolute; z-index: 5; left: 50%; top: 50%; width: 180px; height: 180px; display: grid; place-content: center; padding: 1.4rem; text-align: center; border-radius: 50%; background: var(--acid); box-shadow: 0 24px 58px rgba(77,105,27,.2),0 0 0 18px rgba(201,243,111,.15); transform: translate(-50%,-50%); }
  .signal-map__core strong { font: 800 1rem/1.25 var(--font-head); }
  .signal-map__core small { margin-top: .5rem; color: rgba(7,26,36,.72); font: 800 .55rem var(--font-head); letter-spacing: .12em; text-transform: uppercase; }
  .impact-section { padding-top: 2.6rem; padding-bottom: 3rem; }
  .impact-petal { position: relative; min-height: 190px; padding: 3rem 4.25rem; box-shadow: var(--shadow-soft); }
  .impact-petal span { color: rgba(7,26,36,.68); font: 850 .58rem var(--font-head); letter-spacing: .14em; text-transform: uppercase; }
  .impact-petal h3 { margin: 2rem 0 .7rem; font-size: 1.65rem; }
  .impact-petal p { color: var(--ink-soft); font-size: .84rem; }
  .impact-petal--support { border-radius: 150px 60px 108px 94px / 88px 64px 44px 90px; background: var(--signal-soft); }
  .impact-petal--sales { border-radius: 58px 148px 92px 118px / 62px 90px 86px 46px; background: var(--coral-soft); }
  .impact-petal--ops { border-radius: 108px 90px 56px 146px / 46px 86px 88px 64px; background: var(--sky-soft); }
  .impact-petal--lead { border-radius: 94px 116px 150px 58px / 88px 44px 64px 92px; background: #ece4ff; }
  .impact-core { position: absolute; z-index: 4; left: 50%; top: 50%; width: 196px; height: 196px; display: grid; place-content: center; padding: 1.5rem; color: var(--white); border-radius: 52% 48% 55% 45% / 43% 60% 40% 57%; background: var(--night-soft); box-shadow: 0 25px 60px rgba(7,26,36,.28),0 0 0 17px rgba(7,26,36,.04); text-align: center; transform: translate(-50%,-50%); }
  .impact-core span { color: var(--signal); font: 850 .55rem var(--font-head); letter-spacing: .13em; text-transform: uppercase; }
  .impact-core strong { margin-top: .55rem; font: 780 .93rem/1.32 var(--font-head); }

  /* Clearing the core, take two. Padding the text away from it worked but
     stretched every card into a flat lozenge — the organic radii are
     percentages, so a wide short box renders as an ellipse and the islands
     stopped reading as islands.

     Instead the cards keep their proportions and move outward, which opens a
     gap down the middle for the core to live in. The width is derived, not
     guessed: each card gives up 136px so the pair leaves ≥272px between them,
     and the core is 196px. It holds at every column width rather than at the
     one I happened to screenshot. */
  .signal-island, .impact-petal { max-width: calc(100% - 8.5rem); }
  .signal-island--support, .signal-island--ops,
  .impact-petal--support, .impact-petal--ops { justify-self: start; }
  .signal-island--sales, .signal-island--lead,
  .impact-petal--sales, .impact-petal--lead { justify-self: end; }
  /* THE DOSSIER — the second case.
     Documents on a desk, not a ladder down a shaft. Nothing collapses here:
     the argument IS seeing the exhibits next to each other, so hiding them
     behind a chevron would hide the case. A is full width because it carries
     five contradicting sources; C goes dark because three lines of it take the
     whole company apart, and it should be the thing the eye lands on. */
  .dossier-section { padding: 3.4rem 0 4rem; }
  .dossier-sting { margin-top: .9rem; color: var(--ink); font-weight: 650; }
  .dossier-brief { max-width: 78ch; margin: 2.4rem 0; padding-left: clamp(1rem,2.5vw,1.8rem); border-left: 2px solid var(--signal-deep); }
  .dossier-brief blockquote { margin: .8rem 0 1.2rem; color: var(--ink); font: 700 clamp(1.3rem,1rem + 1.4vw,2rem)/1.3 var(--font-head); letter-spacing: -.02em; text-wrap: balance; }
  .dossier-brief p { margin-bottom: .8rem; color: var(--ink-soft); font-size: .88rem; line-height: 1.68; }
  .dossier-brief p:last-child { margin-bottom: 0; }

  .exhibit { padding: clamp(1.5rem,3vw,2.3rem); border: 1px solid var(--paper-line); border-radius: 74px 26px 66px 30px; background: var(--paper-bright); box-shadow: var(--shadow-soft); }
  .exhibit--wide { border-radius: 82px 28px 74px 32px; }
  .exhibit__tag { display: inline-block; margin-bottom: .5rem; color: var(--signal-deep); font: 850 .58rem var(--font-head); letter-spacing: .16em; text-transform: uppercase; }
  .exhibit h3 { margin-bottom: 1.4rem; font-size: clamp(1.25rem,1rem + .8vw,1.8rem); }
  .exhibit__rows { border-top: 1px solid var(--paper-line); }
  .exhibit__rows > div { display: grid; grid-template-columns: minmax(140px,.42fr) 1fr; gap: .6rem 1.6rem; padding: .85rem 0; border-bottom: 1px solid var(--paper-line); align-items: baseline; }
  .exhibit__rows dt { color: #5c6e75; font: 800 .62rem var(--font-head); letter-spacing: .1em; text-transform: uppercase; }
  .exhibit__rows dd { margin: 0; color: var(--ink); font-size: clamp(.92rem,.85rem + .25vw,1.1rem); line-height: 1.45; }
  .exhibit__note { max-width: 82ch; margin-top: 1.3rem; color: var(--ink-soft); font-size: .86rem; line-height: 1.68; }
  .exhibit__note + .exhibit__note { margin-top: .8rem; }
  .exhibit__note strong { color: var(--ink); font-weight: 700; }

  /* The clock is the exhibit's punchline: the customer and the carrier are
     counting from different days, and neither of them is wrong. */
  .clock { display: flex; flex-wrap: wrap; gap: .5rem 2rem; margin-top: 1.5rem; padding: 1rem 1.2rem; border-radius: 28px 10px 30px 12px; background: var(--signal-soft); }
  .clock li { display: flex; align-items: baseline; gap: .6rem; color: var(--ink-soft); font-size: .8rem; }
  .clock span { color: var(--signal-deep); font: 850 .62rem var(--font-head); letter-spacing: .1em; text-transform: uppercase; }

  .exhibit-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem; margin-top: 1.4rem; align-items: start; }
  .exhibit--dark { color: var(--chalk); border-color: transparent; background: var(--night-soft); border-radius: 30px 78px 34px 70px; box-shadow: var(--shadow-deep); }
  .exhibit--dark .exhibit__tag { color: var(--acid); }
  .exhibit--dark h3 { color: var(--white); }
  .exhibit--dark .exhibit__rows { border-top-color: var(--hairline); }
  .exhibit--dark .exhibit__rows > div { border-bottom-color: var(--hairline); }
  .exhibit--dark .exhibit__rows dt { color: var(--slate); }
  .exhibit--dark .exhibit__rows dd { color: var(--white); }
  .exhibit--dark .exhibit__note { color: var(--slate); }
  .exhibit--dark .exhibit__note strong { color: var(--chalk); }

  .verdict { margin-top: 2.6rem; padding-top: 2rem; border-top: 2px solid var(--ink); }
  .verdict h3 { max-width: 24ch; font-size: clamp(1.5rem,1rem + 1.9vw,2.7rem); line-height: 1.15; text-wrap: balance; }
  .verdict h3 em { color: var(--signal-deep); font-style: normal; }
  .verdict__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem 2.6rem; margin-top: 1.6rem; }
  .verdict__grid p { color: var(--ink-soft); font-size: .88rem; line-height: 1.68; }

  .rebuild { margin-top: 2.6rem; padding: clamp(1.6rem,3vw,2.4rem); border-radius: 26px 70px 30px 78px; background: rgba(17,125,108,.05); border: 1px dashed var(--paper-line-strong); }
  .rebuild p { max-width: 84ch; margin-top: .85rem; color: var(--ink-soft); font-size: .88rem; line-height: 1.68; }
  .rebuild p:first-of-type { margin-top: .7rem; }
  .rebuild strong { color: var(--ink); font-weight: 700; }
  .rebuild em { font-style: italic; }
  .dossier-close { max-width: 84ch; margin-top: 2.2rem; color: var(--ink-soft); font-size: clamp(.92rem,.86rem + .25vw,1.05rem); line-height: 1.7; }
