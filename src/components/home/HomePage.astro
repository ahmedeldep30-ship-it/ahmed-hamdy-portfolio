  .who__lead p { max-width: 66ch; margin-bottom: 1rem; color: var(--ink-soft); font-size: clamp(.95rem, .9rem + .25vw, 1.08rem); line-height: 1.68; }
  .who__lead p:last-child { margin-bottom: 0; }
  .who__lead strong, .who__close strong { color: var(--ink); font-weight: 650; }
