<script>
  /**
   * Pointer parallax on the portrait.
   *
   * This used to bail out entirely on prefers-reduced-motion. Ahmed has
   * reduce-motion on at the OS level, remembered this moving, and found it
   * dead — the same trap the diagnosis animation fell into earlier in this
   * project.
   *
   * Reduced motion is about movement that happens TO you: autoplay, drift,
   * scroll-linked parallax. This happens BECAUSE of you and stops the instant
   * you stop, which makes it closer to a hover state than an animation. It is
   * also what this project's own contract already says — reduced motion
   * suppresses autoplay, not deliberate input. So it stays, at a third of the
   * throw.
   */
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const throwPx = reduced ? 6 : 18;
  // A coarse pointer has no hover, so there is nothing to track.
  if (window.matchMedia('(pointer: fine)').matches) {
    const lens = document.querySelector<HTMLElement>('.system-lens');
    const items = lens?.querySelectorAll<HTMLElement>('[data-parallax]');
    lens?.addEventListener('pointermove', (event) => {
      const bounds = lens.getBoundingClientRect();
      const x = (event.clientX - bounds.left) / bounds.width - .5;
      const y = (event.clientY - bounds.top) / bounds.height - .5;
      items?.forEach((item) => {
        const depth = Number(item.dataset.parallax ?? 0);
        item.style.translate = `${x * throwPx * depth}px ${y * throwPx * depth}px`;
      });
    });
    lens?.addEventListener('pointerleave', () => items?.forEach((item) => { item.style.translate = '0 0'; }));
  }

  /**
   * The case panels collapse by default. Two things need wiring:
   *
   * 1. Content inside a collapsed <details> is display:none, so the
   *    IntersectionObserver that runs the reveal animations never fires for it.
   *    On open, mark every reveal inside as visible immediately — they still
   *    stagger, because the reveal-delay classes carry their own transition
   *    delay, so the case fades in rather than snapping.
   *
   * 2. An in-page link to a collapsed case (the hero buttons point at
   *    #diagnosis and #evidence) should open it before the browser scrolls, or
   *    the anchor lands on a closed panel.
   */
  document.querySelectorAll<HTMLDetailsElement>('details.case').forEach((panel) => {
    panel.addEventListener('toggle', () => {
      if (panel.open)
        panel.querySelectorAll('.reveal:not(.is-visible)').forEach((n) => n.classList.add('is-visible'));
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
    link.addEventListener('click', () => {
      const id = link.getAttribute('href')!.slice(1);
      const target = id && document.getElementById(id);
      if (target instanceof HTMLDetailsElement && !target.open) target.open = true;
    });
  });
</script>
