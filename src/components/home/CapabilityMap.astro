];
---

<section class="section cmap" id="capabilities" aria-labelledby="cmap-h">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Capability proof map</span>
      <h2 id="cmap-h" class="sec-head__q">Every capability has to name what proves it.</h2>
      <p class="muted">
        A capability list is free to write. Select one and it has to show its evidence —
        including where that evidence is still being written.
      </p>
    </div>

    <div class="cmap__ui">
      <div class="cmap__list" role="tablist" aria-orientation="vertical" aria-label="Capabilities">
        {CAPS.map((c, i) => (
          <button
            class="cmap__btn" role="tab" type="button"
            id={`cap-t-${c.id}`} aria-controls={`cap-p-${c.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            data-cap={c.id}
          >
            <span class="cmap__dot" aria-hidden="true"></span>
            {c.name}
          </button>
        ))}
      </div>

      <div class="cmap__panels">
        {CAPS.map((c, i) => (
          <div
            class="cmap__panel" role="tabpanel"
            id={`cap-p-${c.id}`} aria-labelledby={`cap-t-${c.id}`}
            hidden={i !== 0}
          >
            <p class="cmap__claim">{c.claim}</p>
            <p class="eyebrow cmap__pl">Proved by</p>
            <ul class="cmap__proof">
              {c.proof.map((p) => (
                <li class={`cmap__p cmap__p--${p.state}`}>
                  <span class="cmap__p-line" aria-hidden="true"></span>
                  <span class="cmap__p-l">{p.label}</span>
                  {p.state === 'soon' && <span class="cmap__p-s">in preparation</span>}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .cmap__ui { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr); gap: var(--s7); align-items: start; }
  @media (max-width: 900px) { .cmap__ui { grid-template-columns: 1fr; gap: var(--s5); } }

  .cmap__list { display: flex; flex-direction: column; border-top: 1px solid var(--hairline); }
  .cmap__btn {
    display: flex; align-items: center; gap: var(--s3);
    text-align: left; background: none; border: 0;
    border-bottom: 1px solid var(--hairline);
    padding: var(--s4) var(--s2);
    font-family: var(--font-head); font-size: var(--fs-small); font-weight: 600;
    color: var(--text-muted); cursor: pointer;
    transition: color var(--dur-fast) var(--ease), padding-left var(--dur-fast) var(--ease);
  }
  .cmap__btn:hover { color: var(--text); }
  .cmap__btn[aria-selected='true'] { color: var(--teal-bright); padding-left: var(--s4); }
  .cmap__dot {
    width: 7px; height: 7px; border-radius: 50%; flex: none;
    border: 1px solid var(--border-control); background: transparent;
    transition: background var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .cmap__btn[aria-selected='true'] .cmap__dot { background: var(--teal-bright); border-color: var(--teal-bright); }

  .cmap__panel {
    padding: var(--s5); background: var(--surface-raise);
    border: 1px solid var(--hairline); border-radius: var(--r-lg);
  }
  .cmap__claim { font-size: var(--fs-h4); font-family: var(--font-head); font-weight: 600; color: var(--text); margin-bottom: var(--s5); }
  .cmap__pl { margin-bottom: var(--s3); }
  .cmap__proof { display: flex; flex-direction: column; gap: var(--s3); padding: 0; list-style: none; }
  .cmap__p { display: flex; align-items: center; gap: var(--s3); font-size: var(--fs-small); }
  .cmap__p-line { width: 20px; height: 1px; background: var(--teal-signal); flex: none; }
  .cmap__p--soon .cmap__p-line { background: var(--border-control); }
  .cmap__p-l { color: var(--text); }
  .cmap__p--soon .cmap__p-l { color: var(--text-muted); }
  .cmap__p-s {
    font-family: var(--font-head); font-size: var(--fs-label); font-weight: 700;
    letter-spacing: 0.07em; text-transform: uppercase; color: var(--text-faint);
    border: 1px solid var(--hairline-strong); border-radius: 999px; padding: 0.1rem 0.45rem;
  }

  /* Restrained Signal Reconstruction: the connector threads in once. */
  @keyframes cmap-thread { from { width: 0; opacity: 0; } to { width: 20px; opacity: 1; } }
  .cmap__panel:not([hidden]) .cmap__p-line { animation: cmap-thread var(--dur-slow) var(--ease-out) both; }
  .cmap__panel:not([hidden]) .cmap__p:nth-child(2) .cmap__p-line { animation-delay: 60ms; }
  .cmap__panel:not([hidden]) .cmap__p:nth-child(3) .cmap__p-line { animation-delay: 120ms; }
</style>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.cmap__btn'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.cmap__panel'));

  function select(id: string) {
    tabs.forEach((t) => {
      const on = t.dataset.cap === id;
      t.setAttribute('aria-selected', String(on));
      t.tabIndex = on ? 0 : -1;
    });
    panels.forEach((p) => { p.hidden = p.id !== `cap-p-${id}`; });
  }

  tabs.forEach((t) => {
    t.addEventListener('click', () => select(t.dataset.cap!));
    // Hover reveals on pointer devices without stealing focus.
    t.addEventListener('mouseenter', () => {
      if (window.matchMedia('(hover: hover)').matches) select(t.dataset.cap!);
    });
    t.addEventListener('keydown', (e) => {
      const i = tabs.indexOf(t);
      let n = -1;
      if (e.key === 'ArrowDown') n = (i + 1) % tabs.length;
      if (e.key === 'ArrowUp') n = (i - 1 + tabs.length) % tabs.length;
      if (e.key === 'Home') n = 0;
      if (e.key === 'End') n = tabs.length - 1;
      if (n < 0) return;
      e.preventDefault();
      const next = tabs[n]!;
      select(next.dataset.cap!);
      next.focus();
    });
  });
</script>
