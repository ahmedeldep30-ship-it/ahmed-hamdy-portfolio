---
/**
 * §5 — Capability Proof Map.
 * Selecting a capability reveals what proves it. Signal Reconstruction in its
 * restrained form: the connection is drawn, not decorated.
 *
 * Rule: every capability must name real proof. Nothing here is aspirational —
 * where proof is still being written, it says so.
 */

type Proof = { label: string; state: 'live' | 'soon' };

const CAPS: { id: string; name: string; claim: string; proof: Proof[] }[] = [
  {
    id: 'growth', name: 'Business growth & strategy',
    claim: 'Finding where growth is actually constrained — which is rarely the ad budget.',
    proof: [
      { label: 'Formula4You — market gap → vertical strategy', state: 'live' },
      { label: 'Growth & Market Expansion playbook', state: 'soon' },
      { label: 'Commercial Growth case study', state: 'soon' },
    ],
  },
  {
    id: 'ops', name: 'Operations & process improvement',
    claim: 'Removing repeated work, owner dependency, and unclear handoffs before automating anything.',
    proof: [
      { label: 'Formula4You — listing lifecycle, admin review, governance', state: 'live' },
      { label: 'Operations & Workflow playbook', state: 'soon' },
      { label: 'Alpha Capital — friction → operational insight', state: 'soon' },
    ],
  },
  {
    id: 'cx', name: 'Customer experience & support transformation',
    claim: 'Treating contact volume as evidence, not as a staffing problem.',
    proof: [
      { label: 'Support & CX Transformation playbook', state: 'soon' },
      { label: 'Alpha Capital — contact drivers', state: 'soon' },
      { label: 'Seam Diagnosis — post-purchase silence', state: 'live' },
    ],
  },
  {
    id: 'uiux', name: 'Conversion-focused UI/UX',
    claim: 'Judging interface by commercial clarity and information timing — never by visual taste.',
    proof: [
      { label: 'Formula4You — storefront & discovery requirements', state: 'live' },
      { label: 'E-commerce Conversion case study', state: 'soon' },
      { label: 'Digital Buying-System playbook', state: 'soon' },
    ],
  },
  {
    id: 'journey', name: 'Customer journey optimization',
    claim: 'Designing the whole path — including the silence customers feel after paying.',
    proof: [
      { label: 'Seam Diagnosis — the break lives in the handoff', state: 'live' },
      { label: 'Formula4You — onboarding to first order', state: 'live' },
      { label: 'E-commerce Conversion case study', state: 'soon' },
    ],
  },
  {
    id: 'product', name: 'Product & feature strategy',
    claim: 'Deciding what earns a build — and what earns a sentence instead.',
    proof: [
      { label: 'Formula4You — phased scope, feature-bloat prevention', state: 'live' },
      { label: 'Simplify → Automate → Build framework', state: 'live' },
      { label: 'Intervention Compression — nine options to two', state: 'live' },
    ],
  },
  {
    id: 'gtm', name: 'Go-to-market planning',
    claim: 'Sequencing a launch so it survives its own first month.',
    proof: [
      { label: 'Formula4You — supply-first launch sequence', state: 'live' },
      { label: 'Formula4You — participant value propositions', state: 'live' },
      { label: 'Growth & Market Expansion playbook', state: 'soon' },
    ],
  },
  {
    id: 'market', name: 'Market-gap analysis & expansion',
    claim: 'Testing whether a gap is structural before committing resources to it.',
    proof: [
      { label: 'Formula4You — the gap is the case study', state: 'live' },
      { label: 'Strategic Audit Method', state: 'live' },
      { label: 'Market-expansion diagnostic', state: 'soon' },
    ],
  },
  {
    id: 'exec', name: 'Cross-functional execution',
    claim: 'Turning a decision into briefs, sequence, QA, and a measurement defined before launch.',
    proof: [
      { label: 'Formula4You — design, content, technical, QA, SEO coordination', state: 'live' },
      { label: 'Formula4You — requirements & acceptance logic', state: 'live' },
      { label: 'Commercial Growth — feedback loop', state: 'soon' },
    ],
  },
  {
    id: 'ai', name: 'AI-aware business decisions',
    claim: 'Knowing when not to automate. The restraint is the skill.',
    proof: [
