---
/**
 * SEAM DIAGNOSIS — the hero.
 *
 * The customer experiences one continuous journey. The company is organised as
 * five separate functions. The break falls in a HANDOFF — a place no single
 * department owns and no dashboard measures.
 *
 * PLACEMENT IS THE FEATURE, not decoration. Measured before this rewrite, the
 * figure sat 780px down with the SVG starting at 878px — below the fold at
 * 1920, 1440, 1366 and 1024. It could never play on arrival, so the argument
 * only existed for people who scrolled. The copy is now tight enough that the
 * instrument lands inside the first viewport and plays as the page opens.
 * scripts/verify-hero-fold.mjs holds that line.
 *
 * Contract:
 *  · Base state IS the complete, annotated, resolved diagram. Killing the
 *    animation never leaves a blank frame — it leaves the whole argument.
 *  · Six beats over ~4.4s, paced to be read. Plays once. Never loops.
 *  · Reduced motion never autoplays; the control still works on request.
 *  · Meaning lives in semantic HTML; SVG is aria-hidden illustration.
 */

const STAGES = [
  { x: 70, label: 'Discover' },
  { x: 242, label: 'Understand' },
  { x: 414, label: 'Decide' },
  { x: 586, label: 'Buy' },
  { x: 758, label: 'Receive' },
  { x: 930, label: 'Return' },
];

const DEPTS = [
  { x: 40, cx: 127, label: 'Marketing', state: 'cause', note: 'contributes' },
  { x: 226, cx: 313, label: 'Website & Product', state: 'cause', note: 'contributes' },
  { x: 412, cx: 499, label: 'Sales & Checkout', state: 'ok', note: 'working correctly' },
  { x: 598, cx: 685, label: 'Operations', state: 'cause', note: 'contributes' },
  { x: 784, cx: 871, label: 'Support & Retention', state: 'symptom', note: 'symptom shows here' },
];

const OWNS: [number, number][] = [
  [70, 127], [242, 313], [414, 313], [586, 499], [758, 685], [930, 871],
];

const FINDINGS = [
  { n: 1, dept: 'Marketing', text: 'The promise started here — “next-day delivery”.' },
  { n: 2, dept: 'Website & Product', text: 'The missing information sits here — delivery time only appears at checkout.' },
  { n: 3, dept: 'Operations', text: 'The real delay lives here — fulfilment takes three days.' },
  { n: 4, dept: 'Support', text: 'The symptom only surfaces here — “Where is my order?”' },
];

/* Mobile: same reasoning, laid out HORIZONTALLY and compactly.
   The old mobile variant was a 560-tall vertical stack — correct but
   interminable, and it made the page feel like a column of unrelated bits.
   Here the journey stays a horizontal line (which is the whole metaphor:
   the customer experiences ONE line), labels alternate above/below so each
   gets double the room, and the five functions are carried by the HTML
   findings below rather than crammed into unreadable 8px chips. */
const M_STAGES = [
  { x: 28, label: 'Discover', y: 74 },
  { x: 85, label: 'Understand', y: 92 },
  { x: 142, label: 'Decide', y: 74 },
  { x: 199, label: 'Buy', y: 92 },
  { x: 256, label: 'Receive', y: 74 },
  { x: 314, label: 'Return', y: 92 },
];
---

<section class="section seam-sec" id="diagnosis" aria-labelledby="dx-h">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">A worked diagnosis</span>
      <h2 id="dx-h" class="sec-head__q">Support volume is rising after purchase. Watch where the problem actually lives.</h2>
      <p class="muted">
        Not a case study — a demonstration. This is the reasoning I run on any business, in
        about four seconds.
      </p>
    </div>

    <figure class="seam" data-seam>

      <!-- Meaning lives here: always in the DOM, always crawlable, always in the
           accessibility tree regardless of which SVG variant is displayed. -->
      <p class="visually-hidden">
        The customer experiences one continuous journey: discover, understand, decide, buy,
        receive, return. The company is organised as five separate functions: marketing;
        website and product; sales and checkout; operations; support and retention. The
        customer's journey breaks between buying and receiving — in the handoff between sales
        and operations. Four functions contribute: marketing promised next-day delivery, the
        website reveals delivery time only at checkout, operations takes three days to fulfil,
        and the symptom surfaces in support as repeated “where is my order?” contacts. No
        single department owns the break. The resolution connects the four functions with one
        owner for post-purchase certainty and three timed updates — not a new product.
      </p>

      <!-- One stage wrapping both variants: its box always tracks whichever
           diagram is actually displayed, so the play trigger works at every
           width without knowing which SVG is visible. -->
      <div class="seam__stage" data-seam-stage>
      <!-- ── DESKTOP INSTRUMENT ──────────────────────────────────────────── -->
      <svg class="seam__svg seam__svg--wide" viewBox="0 0 1000 272" aria-hidden="true" focusable="false">
        <g class="s-journey">
          <text class="s-lab" x="0" y="12">THE CUSTOMER EXPERIENCES ONE JOURNEY</text>
          <path class="s-line s-fx-line" pathLength="1" d="M 70 40 L 596 40" />
          <path class="s-line s-fx-line s-fx-line--b" pathLength="1" d="M 748 40 L 930 40" />

          <g class="s-fx-break">
            <path class="s-break" d="M 596 40 L 748 40" />
            <path class="s-break-cap" d="M 596 30 L 596 50" />
            <path class="s-break-cap" d="M 748 30 L 748 50" />
            <text class="s-t s-t--f" x="672" y="24" text-anchor="middle">the break</text>
          </g>

          {STAGES.map((s) => (
            <g class="s-fx-stage">
              <circle class="s-dot" cx={s.x} cy="40" r="4.5" />
              <text class="s-t" x={s.x} y="66" text-anchor="middle">{s.label}</text>
            </g>
          ))}
        </g>

        <g class="s-fx-own">
          {OWNS.map(([sx, dx]) => (
            <path class="s-own" d={`M ${sx} 46 C ${sx} 108, ${dx} 108, ${dx} 148`} />
          ))}
        </g>

        <g class="s-fx-break">
          <path class="s-seam-line" d="M 592 48 L 592 208" />
          <text class="s-t s-t--f" x="592" y="224" text-anchor="middle">no owner in this gap</text>
        </g>

        <g class="s-fx-dept">
          <text class="s-lab" x="0" y="134">THE COMPANY IS ORGANISED AS FIVE SEPARATE FUNCTIONS</text>
          {DEPTS.map((d) => (
            <g>
              <rect class={`s-box s-box--${d.state}`} x={d.x} y="148" width="174" height="52" rx="8" />
              <text class="s-t s-t--box" x={d.cx} y="171" text-anchor="middle">{d.label}</text>
              <text class={`s-t s-t--micro ${d.state === 'ok' ? 's-t--mute' : 's-t--f'}`} x={d.cx} y="188" text-anchor="middle">{d.note}</text>
            </g>
          ))}
        </g>

        <g class="s-fx-resolve">
          <path class="s-connect" pathLength="1"
                d="M 127 240 C 300 240, 300 250, 499 250 C 700 250, 700 240, 871 240" />
          <circle class="s-cnode" cx="127" cy="240" r="4" />
          <circle class="s-cnode" cx="313" cy="245" r="4" />
          <circle class="s-cnode" cx="685" cy="245" r="4" />
          <circle class="s-cnode" cx="871" cy="240" r="4" />
          <text class="s-t s-t--ok" x="499" y="268" text-anchor="middle">one connected path — one owner, three timed updates</text>
        </g>
      </svg>

      <!-- ── MOBILE INSTRUMENT: horizontal, compact, same reasoning order ─── -->
      <svg class="seam__svg seam__svg--tall" viewBox="0 0 342 168" aria-hidden="true" focusable="false">
        <text class="s-lab" x="0" y="12">THE CUSTOMER EXPERIENCES ONE JOURNEY</text>

        <path class="s-line s-fx-line" pathLength="1" d="M 28 50 L 205 50" />
        <path class="s-line s-fx-line s-fx-line--b" pathLength="1" d="M 250 50 L 314 50" />

        <g class="s-fx-break">
          <path class="s-break" d="M 205 50 L 250 50" />
          <path class="s-break-cap" d="M 205 42 L 205 58" />
          <path class="s-break-cap" d="M 250 42 L 250 58" />
          <text class="s-t s-t--f s-t--micro" x="227" y="34" text-anchor="middle">the break</text>
        </g>

        {M_STAGES.map((s) => (
          <g class="s-fx-stage">
            <circle class="s-dot" cx={s.x} cy="50" r="3.5" />
            <text class="s-t s-t--micro" x={s.x} y={s.y} text-anchor="middle">{s.label}</text>
          </g>
        ))}

        <g class="s-fx-break">
          <text class="s-t s-t--f s-t--micro" x="171" y="116" text-anchor="middle">nobody owns this handoff</text>
        </g>

        <g class="s-fx-resolve">
          <path class="s-connect" pathLength="1" d="M 28 134 L 314 134" />
          <circle class="s-cnode" cx="28" cy="134" r="3.5" />
          <circle class="s-cnode" cx="123" cy="134" r="3.5" />
          <circle class="s-cnode" cx="219" cy="134" r="3.5" />
          <circle class="s-cnode" cx="314" cy="134" r="3.5" />
          <text class="s-t s-t--ok s-t--micro" x="171" y="158" text-anchor="middle">one owner, three timed updates</text>
        </g>
      </svg>
      </div>

      <!-- Findings: HTML, not SVG. Readable, crawlable, responsive — and on
           mobile these carry the five functions the compact diagram omits. -->
      <ol class="seam__find">
        {FINDINGS.map((f) => (
          <li class="seam__f s-fx-find">
            <span class="seam__f-n tnum">{String(f.n).padStart(2, '0')}</span>
            <span class="seam__f-d">{f.dept}</span>
            <span class="seam__f-t">{f.text}</span>
          </li>
        ))}
      </ol>

      <p class="seam__conc s-fx-conc">
        <strong>No single department owns the problem.</strong> Each one was doing its job
        correctly. The break is in the handoff — so the fix is not a new feature, and it is not
        more support agents. It is one owner for post-purchase certainty and three timed updates.
      </p>

      <div class="seam__bar">
        <button class="seam__replay" type="button" data-seam-replay>
          <svg viewBox="0 0 12 12" width="11" height="11" aria-hidden="true">
            <path d="M6 1a5 5 0 1 0 5 5" fill="none" stroke="currentColor" stroke-width="1.5" />
            <path d="M6 -1.2 L6 3 L2.4 1" fill="currentColor" />
          </svg>
          <span class="seam__default">Replay diagnosis</span>
          <span class="seam__rm">Play the diagnosis</span>
        </button>
        <span class="faint">
          <span class="seam__default">Plays once on arrival · full static diagram without motion</span>
          <span class="seam__rm">
            Your system asks for reduced motion, so nothing plays on its own —
            the full diagram is already shown above. Press play to watch it build.
          </span>
        </span>
      </div>
    </figure>

  </div>
</section>

<style>
  .seam { margin: 0; }
  .seam__cap {
    display: flex; align-items: baseline; gap: var(--s3); flex-wrap: wrap;
    padding-bottom: var(--s3); margin-bottom: var(--s4);
    border-bottom: 1px solid var(--hairline);
  }
  .seam__svg { width: 100%; height: auto; overflow: visible; display: block; }
  .seam__svg--tall { display: none; }

  @media (max-width: 900px) {
    .seam__svg--wide { display: none; }
    .seam__svg--tall { display: block; }
  }

  /* ── SVG semantics ─────────────────────────────────────────────────── */
  .s-lab { font-family: var(--font-head); font-size: 10px; font-weight: 700; letter-spacing: 0.12em; fill: var(--text-faint); }
  .s-t { font-family: var(--font-body); font-size: 13px; fill: var(--text-muted); }
  .s-t--box { font-family: var(--font-head); font-weight: 600; fill: var(--text); font-size: 12.5px; }
  .s-t--micro { font-size: 10.5px; }
  .s-t--mute { fill: var(--text-faint); }
  .s-t--f { fill: var(--coral-bright); font-weight: 600; }
  .s-t--ok { fill: var(--teal-bright); font-weight: 600; font-size: 12px; }
  .seam__svg--tall .s-t--ok { font-size: 10.5px; }

  .s-line { fill: none; stroke: var(--text-muted); stroke-width: 2; }
  .s-dot { fill: var(--text); }
  .s-break { fill: none; stroke: var(--coral-signal); stroke-width: 2; stroke-dasharray: 4 5; }
  .s-break-cap { stroke: var(--coral-signal); stroke-width: 2; }
  .s-seam-line { fill: none; stroke: var(--coral-signal); stroke-width: 1; stroke-dasharray: 3 4; opacity: 0.75; }
  .s-own { fill: none; stroke: rgba(168, 182, 194, 0.4); stroke-width: 1.2; }

  .s-box { fill: var(--tint-raise); stroke: var(--hairline-strong); stroke-width: 1; }
  .s-box--cause { fill: var(--tint-coral); stroke: rgba(215, 101, 85, 0.45); }
  .s-box--symptom { fill: var(--tint-coral); stroke: var(--coral-signal); stroke-width: 1.5; }

  .s-connect { fill: none; stroke: var(--teal-signal); stroke-width: 2; }
  .s-cnode { fill: var(--teal-bright); }

  /* ── Findings ──────────────────────────────────────────────────────── */
  .seam__find {
    display: grid; gap: 0; margin: var(--s5) 0 0;
    border-top: 1px solid var(--hairline);
    grid-template-columns: 1fr 1fr;
  }
  .seam__f {
    display: grid; grid-template-columns: auto 1fr; gap: 0 var(--s3);
    padding: var(--s3) var(--s4) var(--s3) 0;
    border-bottom: 1px solid var(--hairline);
    align-items: baseline;
  }
  .seam__f-n { font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; color: var(--coral-bright); }
  .seam__f-d { font-family: var(--font-head); font-size: var(--fs-small); font-weight: 700; color: var(--text); }
  .seam__f-t { grid-column: 2; font-size: var(--fs-small); color: var(--text-muted); }
  @media (max-width: 720px) { .seam__find { grid-template-columns: 1fr; } }

  .seam__conc {
    margin-top: var(--s5); padding: var(--s4) var(--s5);
    border-left: 3px solid var(--teal-signal);
    background: var(--tint-teal);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    font-size: var(--fs-small); color: var(--text-muted);
    max-width: 92ch;
  }
  .seam__conc strong { color: var(--text); }

  .seam__bar { display: flex; align-items: center; gap: var(--s4); flex-wrap: wrap; margin-top: var(--s5); }
  .seam__replay {
    display: inline-flex; align-items: center; gap: var(--s2);
    font-family: var(--font-head); font-size: 0.8125rem; font-weight: 600;
    background: none; border: 1px solid var(--border-control); color: var(--text);
    padding: 0.45rem 0.8rem; border-radius: var(--r-sm); cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .seam__replay:hover { border-color: var(--teal-bright); color: var(--teal-bright); }

  /* ══ MOTION ════════════════════════════════════════════════════════════
     Base state = the finished diagram. `.play` re-reveals it in reasoning
     order. Nothing here is required to understand the page.               */
  @keyframes s-draw { from { stroke-dashoffset: 1; } to { stroke-dashoffset: 0; } }
  @keyframes s-in   { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
  @keyframes s-pop  { from { opacity: 0; } to { opacity: 1; } }

  /* Six beats, paced to be READ rather than glimpsed. ~4.4s total, once.
       0.00s  the journey draws — one continuous line
       0.55s  the six stages label themselves
       1.05s  the five functions appear beneath
       1.60s  ownership connectors trace stage → function
       2.10s  THE BREAK — the beat that matters, given the longest reveal
       2.75s  four findings, one at a time
       3.70s  the resolution connects, then the conclusion                  */
  [data-seam].play .s-fx-line       { stroke-dasharray: 1; animation: s-draw 620ms var(--ease-out) both; }
  [data-seam].play .s-fx-line--b    { animation-delay: 260ms; }
  [data-seam].play .s-fx-stage      { animation: s-in 380ms var(--ease) both; animation-delay: 550ms; }
  [data-seam].play .s-fx-dept       { animation: s-in 460ms var(--ease) both; animation-delay: 1050ms; }
  [data-seam].play .s-fx-own        { animation: s-pop 420ms var(--ease) both; animation-delay: 1600ms; }
  [data-seam].play .s-fx-break      { animation: s-pop 560ms var(--ease) both; animation-delay: 2100ms; }
  [data-seam].play .s-fx-find       { animation: s-in 340ms var(--ease) both; }
  [data-seam].play .s-fx-find:nth-child(1) { animation-delay: 2750ms; }
  [data-seam].play .s-fx-find:nth-child(2) { animation-delay: 2980ms; }
  [data-seam].play .s-fx-find:nth-child(3) { animation-delay: 3210ms; }
  [data-seam].play .s-fx-find:nth-child(4) { animation-delay: 3440ms; }
  [data-seam].play .s-fx-resolve    { stroke-dasharray: 1; animation: s-pop 420ms var(--ease) both; animation-delay: 3700ms; }
  [data-seam].play .s-fx-resolve .s-connect { animation: s-draw 780ms var(--ease-out) both; animation-delay: 3700ms; }
  [data-seam].play .s-fx-conc       { animation: s-in 420ms var(--ease) both; animation-delay: 3950ms; }

  /* Gated on the override so an explicitly requested replay still runs — see
     the note in base.css. Without :not() this silences the Replay button. */
  @media (prefers-reduced-motion: reduce) {
    html:not([data-motion-override]) [data-seam].play * { animation: none !important; }
  }

  /* Reduced-motion visitors get told the control works, rather than pressing a
     button that appears dead. */
  .seam__rm { display: none; }
  [data-seam][data-reduced-motion='true'] .seam__rm { display: inline; }
  [data-seam][data-reduced-motion='true'] .seam__default { display: none; }
</style>

<script>
  import { playOnce } from '@/scripts/play-once';

  const seam = document.querySelector<HTMLElement>('[data-seam]');
  if (seam) {
    // Animate the whole figure, but TRIGGER on the diagram alone. The figure is
    // ~900px tall (findings + conclusion), so its midpoint sits below the fold
    // even when the diagram is fully on screen — watching it meant the hero
    // never played on arrival at 1366 or 1280.
    const stage = seam.querySelector<HTMLElement>('[data-seam-stage]');
    // duration MUST outlast the last keyframe (3950ms + 420ms). `.play` is
    // removed when it elapses, so a short value amputates the sequence.
    const { run } = playOnce(seam, { duration: 4600, delay: 160, trigger: stage });
    document.querySelector('[data-seam-replay]')?.addEventListener('click', run);
  }
</script>
