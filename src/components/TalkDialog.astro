---
import { contact } from '@config/site';

/**
 * The talk dialog.
 *
 * Replaces a 373-line contact page carrying the old design and a form with no
 * backend behind it — a form that cannot submit is theatre, and it was asking
 * people to type into it.
 *
 * There is nothing to type here. Three channels that reach him directly, and
 * the one honest thing to say about what the conversation costs.
 *
 * Built on native <dialog> because the browser already does the hard parts
 * correctly: the top layer, the backdrop, focus trapping, Escape, inert-ing the
 * page behind it, and restoring focus to whatever opened it. Every hand-rolled
 * modal on the web is an attempt to reimplement that list, and most of them
 * miss two or three.
 *
 * Progressive enhancement is real, not decorative: every trigger is an ordinary
 * <a href="/contact">. With JavaScript off it navigates to a page that works.
 * The script upgrades those links to open this instead.
 */
const CHANNELS = [
  {
    href: contact.emailHref,
    k: 'Email',
    v: contact.email,
    note: 'Best for anything with detail in it.',
    external: false,
    path: 'M1.6 3h14.8c.9 0 1.6.7 1.6 1.6v8.8c0 .9-.7 1.6-1.6 1.6H1.6C.7 15 0 14.3 0 13.4V4.6C0 3.7.7 3 1.6 3Zm7.4 6.3 6.6-4.1H2.4L9 9.3Zm0 1.8L1.6 6.5v6.9h14.8V6.5L9 11.1Z',
  },
  {
    href: contact.whatsapp,
    k: 'WhatsApp',
    v: '+20 104 002 0093',
    note: 'Fastest. Text is fine — I do not need a call to start.',
    external: true,
    path: 'M9 0a8.9 8.9 0 0 0-7.6 13.6L0 18l4.5-1.4A8.9 8.9 0 1 0 9 0Zm0 16.2a7.2 7.2 0 0 1-3.7-1l-.3-.2-2.7.8.8-2.6-.2-.3A7.3 7.3 0 1 1 9 16.2Zm4-5.4c-.2-.1-1.3-.7-1.5-.8-.2-.1-.4-.1-.5.1l-.7.9c-.1.2-.3.2-.5.1a6 6 0 0 1-3-2.6c-.2-.3.1-.4.3-.7l.3-.5v-.5l-.6-1.5c-.2-.4-.4-.3-.5-.3h-.5c-.2 0-.5.1-.7.3-.3.3-.9.9-.9 2.1s.9 2.5 1 2.6a9.4 9.4 0 0 0 3.7 3.3c1.3.5 1.6.4 1.9.4.4 0 1.3-.5 1.5-1 .2-.6.2-1 .1-1.1l-.4-.2Z',
  },
  {
    href: contact.linkedin,
    k: 'LinkedIn',
    v: 'ahmed-hamdy-growth-operations',
    note: 'If you would rather see the profile first.',
    external: true,
    path: 'M4.5 3.5a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM.6 16h3.8V6.6H.6V16Zm6.3 0h3.8v-5.2c0-1.4.3-2.7 2-2.7 1.7 0 1.7 1.6 1.7 2.8V16H18v-5.9c0-3.3-.7-5.8-4.5-5.8-1.8 0-3 1-3.5 1.9h-.1V6.6H6.9V16Z',
  },
];
---

<dialog class="talk" id="talk-dialog" aria-labelledby="talk-h">
  <div class="talk__panel">
    <button class="talk__x" type="button" data-talk-close aria-label="Close">
      <svg viewBox="0 0 14 14" width="14" height="14" aria-hidden="true"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
    </button>

    <span class="talk__eyebrow">Talk to me</span>
    <h2 id="talk-h">Tell me what is not working.</h2>
    <p class="talk__lede">No form, and nothing to fill in. These three reach me directly, and I answer them myself.</p>

    <ul class="talk__list">
      {CHANNELS.map((c) => (
        <li>
          <a class="tchan" href={c.href} rel={c.external ? 'noopener' : undefined}>
            <span class="tchan__i" aria-hidden="true">
              <svg viewBox="0 0 18 18" width="17" height="17" focusable="false"><path d={c.path} fill="currentColor" /></svg>
            </span>
            <span class="tchan__b">
              <span class="tchan__k">{c.k}</span>
              <span class="tchan__v">{c.v}</span>
              <span class="tchan__n">{c.note}</span>
            </span>
            <span class="tchan__go" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>

    <p class="talk__free">
      <strong>The first conversation is free, and it is not a favour.</strong>
      An hour inside a real problem teaches me more than a month of reading about one, so I get as much out of it as you do. Bring the thing that is actually annoying you — not the tidy version.
    </p>
    <p class="talk__fine">
      Messages are read and answered personally. I do not promise a response time, because I will not promise one I cannot keep. If the problem is not a fit for what I do, I will say so — that is useful to both of us.
    </p>
  </div>
</dialog>

<style>
  /* `margin: auto` is what centres a native modal — the UA stylesheet sets it,
     and our reset's `* { margin: 0 }` silently takes it away. Without this the
     dialog pins itself to the top-left corner, and every click meant for the
     backdrop lands inside the panel instead. */
  .talk { margin: auto; width: min(560px, calc(100vw - 2rem)); max-height: min(88vh, 780px); padding: 0; overflow: visible; color: var(--chalk); border: 1px solid var(--hairline-strong); border-radius: 44px 16px 48px 20px; background: var(--night-soft); box-shadow: 0 40px 110px rgba(0,0,0,.55); }
  .talk::backdrop { background: rgba(3, 14, 20, .68); backdrop-filter: blur(6px); }
  .talk__panel { max-height: inherit; overflow-y: auto; padding: clamp(1.6rem, 4vw, 2.6rem); border-radius: inherit; }

  .talk__x { position: absolute; top: .85rem; right: .85rem; display: grid; place-items: center; width: 38px; height: 38px; color: var(--chalk); border: 1px solid var(--hairline-strong); border-radius: 50%; background: rgba(255,255,255,.05); cursor: pointer; transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease); }
  .talk__x:hover { color: var(--ink); background: var(--signal); border-color: transparent; }
  .talk__x:focus-visible { outline: 2px solid var(--acid); outline-offset: 2px; }

  .talk__eyebrow { display: inline-block; color: var(--signal); font: 850 .6rem var(--font-head); letter-spacing: .16em; text-transform: uppercase; }
  .talk h2 { margin: .6rem 0 .5rem; max-width: 16ch; color: var(--white); font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.3rem); letter-spacing: -.02em; }
  .talk__lede { color: var(--slate); font-size: .88rem; line-height: 1.6; }

  .talk__list { display: grid; gap: .6rem; margin: 1.5rem 0; padding: 0; list-style: none; }
  .tchan { display: grid; grid-template-columns: auto 1fr auto; gap: .95rem; align-items: center; padding: .9rem 1rem; border: 1px solid var(--hairline); border-radius: 26px 9px 28px 11px; background: rgba(255,255,255,.04); text-decoration: none; transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease); }
  .tchan:hover { border-color: var(--signal); background: rgba(72,224,187,.08); transform: translateX(3px); }
  .tchan:focus-visible { outline: 2px solid var(--acid); outline-offset: 3px; }
  .tchan__i { display: grid; place-items: center; width: 38px; height: 38px; flex: none; color: var(--signal); border-radius: 50%; background: rgba(72,224,187,.12); }
  .tchan__b { display: flex; flex-direction: column; gap: .1rem; min-width: 0; }
  .tchan__k { color: var(--slate-soft); font: 800 .58rem var(--font-head); letter-spacing: .12em; text-transform: uppercase; }
  .tchan__v { color: var(--white); font: 750 .88rem var(--font-head); overflow-wrap: anywhere; }
  .tchan__n { color: var(--slate); font-size: .74rem; }
  .tchan__go { color: var(--signal); font: 800 1rem var(--font-head); transition: transform var(--dur-fast) var(--ease); }
  .tchan:hover .tchan__go { transform: translateX(3px); }

  .talk__free { padding: .95rem 1.1rem; border-left: 2px solid var(--acid); border-radius: 0 14px 14px 0; background: rgba(201,243,111,.07); color: var(--slate); font-size: .82rem; line-height: 1.6; }
  .talk__free strong { color: var(--chalk); font-weight: 750; }
  .talk__fine { margin-top: 1rem; color: var(--slate-soft); font-size: .74rem; line-height: 1.6; }

  /* The dialog animates in, and only in. `allow-discrete` is what lets display
     participate, so it does not pop from nothing. */
  @media (prefers-reduced-motion: no-preference) {
    .talk { opacity: 0; translate: 0 12px; transition: opacity .22s var(--ease), translate .22s var(--ease), overlay .22s allow-discrete, display .22s allow-discrete; }
    .talk[open] { opacity: 1; translate: 0 0; }
    @starting-style { .talk[open] { opacity: 0; translate: 0 12px; } }
    .talk::backdrop { opacity: 0; transition: opacity .22s var(--ease), overlay .22s allow-discrete, display .22s allow-discrete; }
    .talk[open]::backdrop { opacity: 1; }
    @starting-style { .talk[open]::backdrop { opacity: 0; } }
  }
</style>

<script>
  const dialog = document.getElementById('talk-dialog') as HTMLDialogElement | null;

  if (dialog && typeof dialog.showModal === 'function') {
    // Every link to the contact page becomes a trigger. The href stays exactly
    // as it is, so middle-click, Ctrl-click and a JS failure all still work.
    const triggers = document.querySelectorAll<HTMLAnchorElement>('a[href$="/contact"], a[href$="/contact/"]');

    triggers.forEach((a) => {
      a.addEventListener('click', (e) => {
        // Leave the modifier gestures alone — someone Ctrl-clicking wants a tab.
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || (e as MouseEvent).button !== 0) return;
        e.preventDefault();
        dialog.showModal();
      });
    });

    dialog.querySelectorAll<HTMLElement>('[data-talk-close]').forEach((b) =>
      b.addEventListener('click', () => dialog.close()),
    );

    // Clicking the backdrop closes it. The dialog's own rect is the test —
    // clicks on the backdrop report the <dialog> as their target, so checking
    // the target alone would close it whenever the padding was hit.
    dialog.addEventListener('click', (e) => {
      const r = dialog.getBoundingClientRect();
      const inside =
        e.clientX >= r.left && e.clientX <= r.right && e.clientY >= r.top && e.clientY <= r.bottom;
      if (!inside) dialog.close();
    });
  }
</script>
